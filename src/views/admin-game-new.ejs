<%- include('partials/header', { title: 'Новая игра', user }) %>
<section class="card narrow">
  <h1>Создать игру</h1>
  <form id="new-game-form">
    <label>Название игры</label>
    <input type="text" name="title" maxlength="100" required />
    <label>Раунды и категории (опционально)</label>
    <textarea name="roundsText" rows="6" placeholder="Раунд 1: История, Кино, Музыка&#10;Раунд 2: Спорт, Наука"></textarea>
    <button class="button" type="submit">Создать</button>
  </form>
  <div id="result"></div>
</section>

<script>
  document.getElementById('new-game-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const roundsText = String(formData.get('roundsText') || '').trim();
    const rounds = roundsText
      ? roundsText
          .split('\n')
          .map((line) => line.trim())
          .filter(Boolean)
          .map((line) => {
            const parts = line.split(':');
            const roundName = (parts[0] || '').trim();
            const categories = (parts[1] || '')
              .split(',')
              .map((item) => item.trim())
              .filter(Boolean);
            return { name: roundName, categories };
          })
      : [];

    const payload = { title: formData.get('title'), rounds };

    const response = await fetch('/api/admin/games', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    const data = await response.json();
    const result = document.getElementById('result');

    if (!response.ok) {
      result.innerHTML = '<div class="error">' + (data.error || 'Ошибка') + '</div>';
      return;
    }

    result.innerHTML = '<div class="success">Игра создана. Код: <code>' + data.code + '</code>. <a href="/admin/games/' + data.gameId + '/control">Перейти к управлению</a></div>';
  });
</script>
<%- include('partials/footer') %>
