<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Игрок</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="fullscreen-page">
  <main class="fullscreen-stage">
    <section class="card fullscreen-card" id="player-question">
      <h2 id="question-title">Ожидание начала игры...</h2>
      <div class="timer-strip"><div id="player-timer-fill" class="timer-strip-fill"></div></div>
      <div id="answer-result" class="notice" style="display:none"></div>
      <div id="player-content"></div>
    </section>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const player = <%- JSON.stringify(player) %>;
    const game = <%- JSON.stringify(game) %>;
    const root = document.getElementById('player-content');
    const answerResultBox = document.getElementById('answer-result');
    const questionTitle = document.getElementById('question-title');
    const timerFill = document.getElementById('player-timer-fill');

    let timerInterval = null;
    let answeredQuestionIds = new Set();
    let currentQuestion = null;
    let selectedOptionIndex = null;
    let activeTimerDurationMs = 0;

    function enableFullscreen() {
      if (document.fullscreenElement || !document.documentElement.requestFullscreen) return;
      document.documentElement.requestFullscreen().catch(() => {});
    }
    window.addEventListener('load', enableFullscreen);
    document.addEventListener('click', enableFullscreen, { once: true });

    socket.emit('player:join', {
      gameCode: game.code,
      playerId: player.id,
      sessionToken: player.sessionToken
    });

    socket.on('question:show', (question) => {
      currentQuestion = question;
      selectedOptionIndex = null;
      activeTimerDurationMs = Number(question.payload && question.payload.timeLimitSec ? question.payload.timeLimitSec * 1000 : 0);
      renderQuestion(question);
    });

    socket.on('question:closed', ({ questionId }) => {
      if (currentQuestion && currentQuestion.id === questionId) {
        currentQuestion.status = 'closed';
      }
      lockInputs();
      stopTimer();
    });

    socket.on('question:timer', ({ timerEndsAt, durationMs }) => {
      if (durationMs) activeTimerDurationMs = Number(durationMs);
      startTimer(timerEndsAt || null, activeTimerDurationMs);
    });

    socket.on('question:answer', ({ type, payload }) => {
      if (type === 'abcd' && payload && Number.isInteger(Number(payload.correct))) {
        const correctIndex = Number(payload.correct);
        root.querySelectorAll('[data-option-index]').forEach((node) => {
          if (Number(node.dataset.optionIndex) === correctIndex) {
            node.classList.add('option-plate-correct');
          }
        });
      }
    });

    socket.on('question:answer', ({ type, payload }) => {
      if (type === 'abcd' && payload && Number.isInteger(Number(payload.correct))) {
        const correctIndex = Number(payload.correct);
        root.querySelectorAll('[data-option-index]').forEach((node) => {
          if (Number(node.dataset.optionIndex) === correctIndex) {
            node.classList.add('option-plate-correct');
          }
        });
      }
    });

    socket.on('buzz:winner', ({ playerId }) => {
      const div = document.createElement('div');
      div.className = 'notice';
      div.innerText = playerId === player.id ? 'Вы нажали первым!' : 'Кто-то уже нажал первым';
      root.appendChild(div);
      lockInputs();
    });

    socket.on('answer:result', ({ questionId, scoreDelta }) => {
      answeredQuestionIds.add(questionId);
      answerResultBox.innerHTML = '';
      if (scoreDelta > 0) {
        answerResultBox.style.display = 'block';
        const bonus = document.createElement('span');
        bonus.className = 'score-bonus-pop';
        bonus.innerText = '+' + scoreDelta;
        answerResultBox.appendChild(bonus);
        setTimeout(() => {
          bonus.remove();
          answerResultBox.style.display = 'none';
        }, 1000);
      } else {
        answerResultBox.style.display = 'none';
      }
      lockInputs();
    });

    socket.on('answer:rejected', ({ reason, message }) => {
      if (reason === 'already_answered' || reason === 'question_closed') return;
      answerResultBox.style.display = 'block';
      answerResultBox.innerText = message || 'Ответ не принят';
    });

    function lockInputs() {
      root.querySelectorAll('button, input').forEach((el) => {
        el.disabled = true;
      });
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
      timerFill.style.width = '0%';
    }

    function startTimer(timerEndsAt, durationMs) {
      stopTimer();
      if (!timerEndsAt) return;

      function tick() {
        const msLeft = Math.max(0, timerEndsAt - Date.now());
        if (durationMs > 0) {
          const percent = Math.max(0, Math.min(100, (msLeft / durationMs) * 100));
          timerFill.style.width = percent + '%';
        }
        if (msLeft <= 0) stopTimer();
      }

      tick();
      timerInterval = setInterval(tick, 100);
    }

    function canSubmit(question) {
      if (!question || question.status !== 'active') return false;
      return !answeredQuestionIds.has(question.id);
    }

    function renderQuestionImage(payload) {
      if (!payload || !payload.imageUrl) return;
      const image = document.createElement('img');
      image.src = payload.imageUrl;
      image.alt = 'Изображение вопроса';
      image.className = 'question-media';
      root.appendChild(image);
    }

    function markSelectedOption(index) {
      root.querySelectorAll('[data-option-index]').forEach((node) => {
        if (Number(node.dataset.optionIndex) === index) {
          node.classList.add('option-selected');
        }
      });
    }

    function renderQuestion(question) {
      root.innerHTML = '';
      answerResultBox.style.display = 'none';
      answerResultBox.innerHTML = '';
      questionTitle.innerText = question.title;
      startTimer(question.timerEndsAt, activeTimerDurationMs);
      renderQuestionImage(question.payload);

      const submitAllowed = canSubmit(question);

      if (question.type === 'abcd') {
        const optionsGrid = document.createElement('div');
        optionsGrid.className = 'options-grid';

        question.payload.options.forEach((option, index) => {
          const btn = document.createElement('button');
          btn.className = 'button option option-plate';
          btn.dataset.optionIndex = String(index);
          btn.innerText = String.fromCharCode(65 + index) + '. ' + option;
          btn.disabled = !submitAllowed;
          btn.onclick = () => {
            if (!canSubmit(question)) return;
            selectedOptionIndex = index;
            markSelectedOption(index);
            socket.emit('answer:submit', {
              gameCode: game.code,
              playerId: player.id,
              answer: { optionIndex: index }
            });
            lockInputs();
          };
          optionsGrid.appendChild(btn);
        });

        root.appendChild(optionsGrid);
      } else if (question.type === 'text') {
        const input = document.createElement('input');
        input.type = 'text';
        input.placeholder = 'Ваш ответ';
        input.disabled = !submitAllowed;
        const btn = document.createElement('button');
        btn.className = 'button';
        btn.innerText = 'Ответить';
        btn.disabled = !submitAllowed;
        btn.onclick = () => {
          if (!canSubmit(question)) return;
          socket.emit('answer:submit', {
            gameCode: game.code,
            playerId: player.id,
            answer: { text: input.value }
          });
          lockInputs();
        };
        root.appendChild(input);
        root.appendChild(btn);
      } else if (question.type === 'number') {
        const input = document.createElement('input');
        input.type = 'number';
        input.placeholder = 'Введите число';
        input.disabled = !submitAllowed;
        const btn = document.createElement('button');
        btn.className = 'button';
        btn.innerText = 'Ответить';
        btn.disabled = !submitAllowed;
        btn.onclick = () => {
          if (!canSubmit(question)) return;
          socket.emit('answer:submit', {
            gameCode: game.code,
            playerId: player.id,
            answer: { number: Number(input.value) }
          });
          lockInputs();
        };
        root.appendChild(input);
        root.appendChild(btn);
      } else if (question.type === 'buzz') {
        const btn = document.createElement('button');
        btn.className = 'button big-button';
        btn.innerText = 'ЖМИ!';
        btn.disabled = !submitAllowed;
        btn.onclick = () => {
          if (!canSubmit(question)) return;
          socket.emit('buzz:press', {
            gameCode: game.code,
            playerId: player.id
          });
          lockInputs();
        };
        root.appendChild(btn);
      }

      if (selectedOptionIndex !== null) {
        markSelectedOption(selectedOptionIndex);
      }

      if (!submitAllowed) {
        lockInputs();
      }
    }
  </script>
</body>
</html>
