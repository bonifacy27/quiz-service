<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Экран игры</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="fullscreen-page">
  <main class="fullscreen-stage">
    <section class="card fullscreen-card" id="question-block">
      <div id="screen-content" class="screen-content"></div>
      <div class="screen-meta" id="screen-meta">
        <span id="screen-timer" class="screen-timer-value">—</span>
      </div>
      <div class="timer-strip" id="screen-timer-strip"><div id="timer-strip-fill" class="timer-strip-fill"></div></div>
      <div id="answer-box" class="notice" style="display:none"></div>
    </section>

    <section class="card fullscreen-card" id="qr-block" style="display:none">
      <h2>Подключение игроков</h2>
      <img src="<%= qrDataUrl %>" alt="QR code" class="qr" />
      <p>Код: <code><%= game.code %></code></p>
      <p><a href="<%= qrUrl %>"><%= qrUrl %></a></p>
      <h3>Подключенные игроки</h3>
      <ul id="qr-players-list"></ul>
    </section>

    <section class="card fullscreen-card" id="players-block" style="display:none"><h2>Игроки</h2><ul id="players-list"></ul></section>
    <section class="card fullscreen-card scoreboard-block" id="leaderboard-block" style="display:none">
      <h2 id="leaderboard-title">Промежуточные итоги</h2>
      <div class="table-scroll scoreboard-table-wrap">
        <table class="scoreboard-table"><thead><tr id="leaderboard-head-row"><th>Место</th><th>Игрок</th><th>Итог</th></tr></thead><tbody id="leaderboard-body"></tbody></table>
      </div>
    </section>
    <section class="card fullscreen-card" id="winners-block" style="display:none"><h2>Победители</h2><ol id="winners-list"></ol></section>
    <section class="card fullscreen-card" id="round-scores-block" style="display:none"><h2>Итоги раунда</h2><div id="round-scores"></div></section>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const game = <%- JSON.stringify(game) %>;
    const contentEl = document.getElementById('screen-content');
    const timerEl = document.getElementById('screen-timer');
    const screenMeta = document.getElementById('screen-meta');
    const answerBox = document.getElementById('answer-box');
    const leaderboardBody = document.getElementById('leaderboard-body');
    const leaderboardHeadRow = document.getElementById('leaderboard-head-row');
    const leaderboardTitle = document.getElementById('leaderboard-title');
    const winnersList = document.getElementById('winners-list');
    const playersList = document.getElementById('players-list');
    const qrPlayersList = document.getElementById('qr-players-list');
    const questionBlock = document.getElementById('question-block');
    const qrBlock = document.getElementById('qr-block');
    const leaderboardBlock = document.getElementById('leaderboard-block');
    const playersBlock = document.getElementById('players-block');
    const winnersBlock = document.getElementById('winners-block');
    const roundScoresBlock = document.getElementById('round-scores-block');

    let timerInterval = null;
    let latestLeaderboard = [];
    let latestDetailedLeaderboard = [];
    let latestRounds = [];
    let activeTimerDurationMs = 0;
    let activeMediaElement = null;
    let pendingTimerAfterVideo = false;

    function enableFullscreen() {
      if (document.fullscreenElement || !document.documentElement.requestFullscreen) return;
      document.documentElement.requestFullscreen().catch(() => {});
    }
    window.addEventListener('load', enableFullscreen);
    document.addEventListener('click', enableFullscreen, { once: true });

    socket.emit('screen:join', { gameCode: game.code });

    socket.on('screen:state', (state) => {
      const showQrOnly = Boolean(state.showQr);
      const showLeaderboardOnly = Boolean(state.showLeaderboard);

      if (showQrOnly || showLeaderboardOnly) {
        questionBlock.style.display = 'none';
        playersBlock.style.display = 'none';
        winnersBlock.style.display = 'none';
        roundScoresBlock.style.display = 'none';
        qrBlock.style.display = showQrOnly ? 'block' : 'none';
        leaderboardBlock.style.display = showLeaderboardOnly ? 'block' : 'none';
      } else {
        questionBlock.style.display = 'block';
        qrBlock.style.display = 'none';
        leaderboardBlock.style.display = 'none';
        playersBlock.style.display = state.showPlayers ? 'block' : 'none';
        winnersBlock.style.display = state.showWinners ? 'block' : 'none';
        roundScoresBlock.style.display = state.showRoundScores ? 'block' : 'none';
      }
      renderWinners(latestLeaderboard);
    });

    socket.on('question:show', (question) => {
      answerBox.style.display = 'none';
      stopMediaPlayback();
      showTimerControls();
      renderQuestion(question);
      playQuestionMediaIfNeeded(question);
      const questionVideoUrl = getQuestionVideoUrl(question.payload);
      pendingTimerAfterVideo = Boolean(questionVideoUrl && !question.timerEndsAt);
      activeTimerDurationMs = Number(question.payload && question.payload.timeLimitSec ? question.payload.timeLimitSec * 1000 : 0);
      if (pendingTimerAfterVideo) {
        stopTimer();
      } else {
        startTimer(question.timerEndsAt, activeTimerDurationMs);
      }
    });

    socket.on('question:media:start', ({ questionId, mediaType, mediaUrl, role }) => {
      if (!mediaUrl || (mediaType !== 'audio' && mediaType !== 'video')) return;
      const currentQuestionId = Number(contentEl.dataset.questionId || 0);
      if (currentQuestionId !== Number(questionId || 0)) return;
      startMediaPlayback(mediaType, mediaUrl, role || 'question', questionId);
    });

    socket.on('question:answer', ({ text, type, payload }) => {
      if (type === 'abcd' && payload && Number.isInteger(Number(payload.correct))) {
        const correctIndex = Number(payload.correct);
        const optionNodes = contentEl.querySelectorAll('[data-option-index]');
        optionNodes.forEach((node) => {
          if (Number(node.dataset.optionIndex) === correctIndex) {
            node.classList.add('option-plate-correct');
            node.classList.add('option-plate-correct-animate');
            setTimeout(() => node.classList.remove('option-plate-correct-animate'), 900);
          }
        });
      }
      if (type === 'abcd') {
        answerBox.style.display = 'none';
      } else {
        answerBox.innerText = 'Правильный ответ показан';
        answerBox.style.display = 'block';
      }
    });

    socket.on('question:closed', ({ reason }) => {
      stopTimer();
      if (reason !== 'reveal_answer') {
        stopMediaPlayback();
      }
      pendingTimerAfterVideo = false;
    });

    socket.on('round:show', ({ roundNumber, name, description }) => {
      stopTimer();
      stopMediaPlayback();
      hideTimerControls();
      answerBox.style.display = 'none';
      const roundLabel = roundNumber ? 'Раунд ' + roundNumber : 'Раунд';
      contentEl.innerHTML = '<div class="notice round-only">'
        + '<h2>' + roundLabel + '</h2>'
        + '<h3>' + (name || '') + '</h3>'
        + '<p>' + (description || '') + '</p>'
        + '</div>';
    });

    socket.on('question:timer', ({ timerEndsAt, durationMs }) => {
      if (durationMs) activeTimerDurationMs = Number(durationMs);
      startTimer(timerEndsAt || null, activeTimerDurationMs);
    });

    socket.on('round:finished', ({ rows }) => {
      document.getElementById('round-scores').innerHTML = rows.map((row) => '<div><strong>' + row.name + '</strong>: за раунд ' + row.round_score + ', всего ' + row.total_score + '</div>').join('');
    });

    socket.on('game:finished', () => {
      contentEl.innerHTML = '<div class="notice">Ведущий завершил игру. Можно запускать новую сессию.</div>';
      stopTimer();
      stopMediaPlayback();
      showTimerControls();
    });

    socket.on('player:list', ({ players }) => {
      const connectedPlayers = players.filter((p) => Number(p.connected) === 1);
      const connectedHtml = connectedPlayers.length
        ? connectedPlayers.map((p) => '<li>' + p.name + '</li>').join('')
        : '<li>Пока никто не подключился</li>';
      qrPlayersList.innerHTML = connectedHtml;
      playersList.innerHTML = players.map((p) => '<li>' + p.name + ' — ' + (p.connected ? 'online' : 'offline') + '</li>').join('');
    });

    socket.on('leaderboard:update', ({ leaderboard, detailedLeaderboard, rounds, isFinal }) => {
      latestLeaderboard = Array.isArray(leaderboard) ? leaderboard : [];
      latestDetailedLeaderboard = Array.isArray(detailedLeaderboard) ? detailedLeaderboard : [];
      latestRounds = Array.isArray(rounds) ? rounds : [];

      leaderboardTitle.textContent = isFinal ? 'Финал' : 'Промежуточные итоги';

      const roundHeaders = latestRounds.map((round, index) => '<th>Раунд ' + (index + 1) + '</th>').join('');
      leaderboardHeadRow.innerHTML = '<th>Место</th><th>Игрок</th>' + roundHeaders + '<th>Итог</th>';

      const rowsToRender = latestDetailedLeaderboard.length ? latestDetailedLeaderboard : latestLeaderboard.map((row) => ({
        place: row.place,
        name: row.name,
        score: row.score,
        byRound: [],
      }));

      leaderboardBody.innerHTML = '';
      rowsToRender.forEach((row) => {
        const tr = document.createElement('tr');
        const perRound = latestRounds.map((round) => {
          const scoreByRound = (row.byRound || []).find((item) => Number(item.roundId) === Number(round.id));
          return '<td>' + (scoreByRound ? scoreByRound.score : 0) + '</td>';
        }).join('');
        tr.innerHTML = '<td>' + row.place + '</td><td>' + row.name + '</td>' + perRound + '<td><strong>' + row.score + '</strong></td>';
        leaderboardBody.appendChild(tr);
      });

      renderWinners(latestLeaderboard);
    });

    function renderWinners(leaderboard) {
      winnersList.innerHTML = '';
      leaderboard.slice(0, 3).forEach((row) => {
        const li = document.createElement('li');
        li.textContent = row.name + ' — ' + row.score;
        winnersList.appendChild(li);
      });
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
      timerEl.innerText = '—';
      screenMeta.style.background = 'conic-gradient(#22c55e 0deg, #1e293b 0deg)';
    }

    function hideTimerControls() {
      screenMeta.style.display = 'none';
    }

    function showTimerControls() {
      screenMeta.style.display = 'flex';
    }

    function startTimer(timerEndsAt, durationMs) {
      stopTimer();
      if (!timerEndsAt) return;

      function tick() {
        const msLeft = Math.max(0, timerEndsAt - Date.now());
        const secLeft = Math.ceil(msLeft / 1000);
        timerEl.innerText = secLeft + ' сек';

        if (durationMs > 0) {
          const percent = Math.max(0, Math.min(100, (msLeft / durationMs) * 100));
          const angle = (percent / 100) * 360;
          screenMeta.style.background = 'conic-gradient(#22c55e ' + angle + 'deg, #1e293b ' + angle + 'deg)';
        }

        if (msLeft <= 0) {
          stopTimer();
        }
      }

      tick();
      timerInterval = setInterval(tick, 100);
    }

    function renderQuestionImage(payload) {
      if (!payload || !payload.imageUrl) return;
      const image = document.createElement('img');
      image.src = payload.imageUrl;
      image.alt = 'Изображение вопроса';
      image.className = 'question-media';
      contentEl.appendChild(image);
    }

    function renderQuestion(question) {
      contentEl.innerHTML = '';
      contentEl.dataset.questionId = String(question.id || '');
      renderQuestionImage(question.payload);

      const title = document.createElement('h2');
      title.className = 'screen-question-title';
      title.innerText = question.title;
      contentEl.appendChild(title);

      const mediaSlot = document.createElement('div');
      mediaSlot.className = 'question-media-slot';
      contentEl.appendChild(mediaSlot);

      if (question.type === 'abcd' && question.payload && Array.isArray(question.payload.options)) {
        const optionsGrid = document.createElement('div');
        optionsGrid.className = 'options-grid';

        question.payload.options.forEach((option, index) => {
          const item = document.createElement('div');
          item.className = 'option-plate';
          item.dataset.optionIndex = String(index);
          item.innerText = String.fromCharCode(65 + index) + '. ' + option;
          optionsGrid.appendChild(item);
        });

        contentEl.appendChild(optionsGrid);
      } else if (question.type === 'buzz') {
        contentEl.innerHTML += '<div class="big-label">Кто быстрее нажмет первым?</div>';
      } else {
        contentEl.innerHTML += '<div class="notice">Вопрос открыт. Игроки отвечают.</div>';
      }
    }

    function stopMediaPlayback() {
      if (activeMediaElement) {
        activeMediaElement.pause();
        activeMediaElement.removeAttribute('src');
        activeMediaElement.load();
        activeMediaElement.remove();
        activeMediaElement = null;
      }
    }

    function startMediaPlayback(mediaType, mediaUrl, role, questionId) {
      stopMediaPlayback();
      if (mediaType === 'audio') {
        const audio = document.createElement('audio');
        audio.src = mediaUrl;
        audio.autoplay = true;
        audio.controls = false;
        audio.className = role === 'answer' ? 'answer-audio' : 'question-audio';
        activeMediaElement = audio;
        document.body.appendChild(audio);
        audio.play().catch(() => {});
        return;
      }

      if (role !== 'answer') {
        const video = document.createElement('video');
        video.src = mediaUrl;
        video.autoplay = true;
        video.controls = false;
        video.className = 'question-media';
        video.playsInline = true;
        video.setAttribute('playsinline', '');
        video.setAttribute('webkit-playsinline', '');
        video.onended = () => {
          if (pendingTimerAfterVideo && questionId) {
            pendingTimerAfterVideo = false;
            socket.emit('question:media:ended', {
              gameCode: game.code,
              questionId,
              mediaType: 'video',
              role: 'question',
            });
          }
        };
        activeMediaElement = video;
        const mediaSlot = contentEl.querySelector('.question-media-slot');
        if (mediaSlot) mediaSlot.appendChild(video);
        else contentEl.prepend(video);
        video.play().catch(() => {});
        return;
      }

      const video = document.createElement('video');
      video.src = mediaUrl;
      video.autoplay = true;
      video.controls = false;
      video.className = 'question-media';
      video.playsInline = true;
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      activeMediaElement = video;
      const titleNode = contentEl.querySelector('.screen-question-title');
      if (titleNode) titleNode.after(video);
      else contentEl.prepend(video);
      video.play().catch(() => {});
    }

    function playQuestionMediaIfNeeded(question) {
      const payload = question && question.payload ? question.payload : {};
      const questionVideoUrl = String(payload.videoQuestionUrl || '').trim();
      const questionAudioUrl = String(payload.audioQuestionUrl || '').trim();
      const legacyMediaUrl = String(payload.mediaUrl || '').trim();
      const legacyMediaType = payload.mediaType === 'audio' || payload.mediaType === 'video' ? payload.mediaType : '';
      if (questionVideoUrl) {
        startMediaPlayback('video', questionVideoUrl, 'question', question.id);
        return;
      }
      if (questionAudioUrl) {
        startMediaPlayback('audio', questionAudioUrl, 'question', question.id);
        return;
      }
      if (legacyMediaUrl && legacyMediaType) {
        startMediaPlayback(legacyMediaType, legacyMediaUrl, 'question', question.id);
      }
    }

    function getQuestionVideoUrl(payload) {
      if (!payload) return '';
      const videoQuestionUrl = String(payload.videoQuestionUrl || '').trim();
      if (videoQuestionUrl) return videoQuestionUrl;
      const legacyMediaType = payload.mediaType === 'video' ? 'video' : '';
      const legacyMediaUrl = String(payload.mediaUrl || '').trim();
      return legacyMediaType && legacyMediaUrl ? legacyMediaUrl : '';
    }
  </script>
</body>
</html>
