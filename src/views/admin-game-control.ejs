<%- include('partials/header', { title: 'Управление игрой', user }) %>

<section class="card">
  <h1><%= game.title %> • управление игрой</h1>
  <div class="row wrap">
    <a class="button button-outline" href="/admin/games/<%= game.id %>/build">Редактировать игру</a>
  </div>
</section>

<section class="card">
  <h2>1. Начало игры</h2>
  <% const isSessionStarted = Boolean(currentSessionId); %>
  <p>
    <% if (isSessionStarted) { %>
      <a class="button" href="/game/<%= game.code %>" target="_blank" rel="noopener noreferrer">Открыть экран игры</a>
    <% } else { %>
      <span class="muted">Экран станет доступен после запуска новой игры.</span>
    <% } %>
  </p>
  <label>Ссылка для подключения</label>
  <div class="row wrap">
    <input type="text" id="join-link" value="<%= isSessionStarted ? joinUrl : '' %>" readonly placeholder="Появится после запуска новой игры" />
    <button class="icon-button" type="button" id="copy-link" title="Скопировать ссылку" <%= isSessionStarted ? '' : 'disabled' %>>📋</button>
  </div>
  <details>
    <summary>Запуски и история</summary>
    <div class="row wrap">
      <button class="button" id="start-new">Запустить новую игру</button>
      <button class="button button-danger" id="finish-game">Завершить игру</button>
    </div>
    <div class="session-history">
      <% const activeSession = sessions.find((session) => session.id === currentSessionId && session.status === 'live'); %>
      <h3>Текущая сессия</h3>
      <% if (activeSession) { %>
        <p>
          Началась: <strong><%= new Date(activeSession.started_at).toLocaleString('ru-RU') %></strong>,
          игроков онлайн: <strong><%= Number(activeSession.players_online || 0) %></strong>
        </p>
      <% } else { %>
        <p class="muted">Активной сессии сейчас нет.</p>
      <% } %>

      <h3>История завершенных игр</h3>
      <% const finishedSessions = sessions.filter((session) => session.status === 'finished'); %>
      <% if (finishedSessions.length) { %>
        <ul>
          <% finishedSessions.forEach((session) => { %>
            <li>
              Сессия #<%= session.session_number %> — старт <%= new Date(session.started_at).toLocaleString('ru-RU') %>,
              игроков участвовало: <strong><%= Number(session.players_total || 0) %></strong>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted">Завершенных сессий пока нет.</p>
      <% } %>
    </div>
  </details>
</section>

<section class="card">
  <h2>2. Управление экраном игры</h2>
  <div class="row wrap">
    <button class="button button-outline" id="toggle-qr">Показать/скрыть QR-код</button>
    <button class="button button-outline screen-toggle" data-key="showLeaderboard">Показать/скрыть таблицу очков</button>
  </div>
</section>

<section class="card">
  <h2>3. Управление игрой</h2>
  <% if (!rounds.length) { %>
    <p class="notice">Добавьте раунды и вопросы в разделе «Создание игры».</p>
  <% } else { %>
    <label for="round-select">Раунд</label>
    <select id="round-select"></select>
    <div id="question-ribbon" class="question-ribbon"></div>
  <% } %>
</section>

<section class="card">
  <h2>4. Управление игроками</h2>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Игрок</th>
          <th>Статус</th>
          <% rounds.forEach((round, index) => { %>
            <th>Раунд <%= index + 1 %></th>
          <% }) %>
          <th>Итого</th>
        </tr>
      </thead>
      <tbody id="players-score-body"></tbody>
    </table>
  </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const game = <%- JSON.stringify(game) %>;
  const rounds = <%- JSON.stringify(rounds) %>;
  const questionsByRound = <%- JSON.stringify(questionsByRound) %>;
  const initialPlayers = <%- JSON.stringify(players) %>;
  const roundScoreTable = <%- JSON.stringify(roundScoreTable) %>;

  socket.emit('host:join', { gameCode: game.code });

  async function post(url, body = {}) {
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    return response.json();
  }

  document.getElementById('copy-link').onclick = async () => {
    await navigator.clipboard.writeText(document.getElementById('join-link').value);
  };

  document.getElementById('start-new').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/start');
    location.reload();
  };

  const continueCurrent = document.getElementById('continue-current');
  if (continueCurrent) {
    continueCurrent.onclick = async () => {
      await post('/api/admin/games/<%= game.id %>/continue', { sessionId: <%= currentSessionId || 'null' %> });
      location.reload();
    };
  }

  document.getElementById('finish-game').onclick = async () => {
    if (!confirm('Завершить игру сейчас?')) return;
    await post('/api/admin/games/<%= game.id %>/finish');
    location.reload();
  };

  document.querySelectorAll('.screen-toggle').forEach((button) => {
    button.onclick = async () => {
      const data = await post('/api/admin/games/<%= game.id %>/screen', { key: button.dataset.key });
      if (data.screen) {
        button.classList.toggle('button-outline', !data.screen[button.dataset.key]);
      }
    };
  });

  const roundSelect = document.getElementById('round-select');
  const questionRibbon = document.getElementById('question-ribbon');
  const playersScoreBody = document.getElementById('players-score-body');

  let activeQuestionId = null;
  let livePlayers = initialPlayers.slice();
  let liveRoundScores = new Map();
  let answersByQuestion = new Map();
  let playedQuestionIds = new Set();
  let selectedRoundId = rounds.length ? Number(rounds[0].id) : null;

  roundScoreTable.forEach((row) => {
    row.byRound.forEach((roundData) => {
      liveRoundScores.set(row.playerId + ':' + roundData.roundId, Number(roundData.score || 0));
    });
  });

  function optionLetter(index) {
    return String.fromCharCode(65 + index);
  }

  function formatAnswer(question, answer) {
    if (!question) return '—';
    if (question.type === 'abcd') {
      const idx = Number(answer && answer.optionIndex);
      if (!Number.isInteger(idx)) return '—';
      const optionText = question.payload && question.payload.options && question.payload.options[idx] ? question.payload.options[idx] : '';
      return optionLetter(idx) + '. ' + optionText;
    }
    if (question.type === 'text') return String(answer && answer.text || '—');
    if (question.type === 'number') return String(answer && answer.number || '—');
    return JSON.stringify(answer || {});
  }

  function findPlayerName(playerId) {
    const player = livePlayers.find((item) => item.id === playerId);
    return player ? player.name : '#' + playerId;
  }

  function renderAnswerRows(question) {
    const rows = answersByQuestion.get(question.id) || [];
    if (!rows.length) return '<tr><td colspan="3">Ответов пока нет.</td></tr>';
    return rows.map((item) => '<tr>'
      + '<td>' + findPlayerName(item.playerId) + '</td>'
      + '<td>' + formatAnswer(question, item.answer) + '</td>'
      + '<td>' + (item.isCorrect ? '✅ верно' : '❌ неверно') + '</td>'
      + '</tr>').join('');
  }

  function renderQuestionRibbon() {
    if (!roundSelect || !questionRibbon) return;

    const roundId = Number(roundSelect.value);
    const questions = questionsByRound[roundId] || [];
    if (!questions.length) {
      questionRibbon.innerHTML = '<p class="notice">В этом раунде нет вопросов.</p>';
      return;
    }

    questionRibbon.innerHTML = questions.map((question, index) => {
      const optionsHtml = question.type === 'abcd' && question.payload && Array.isArray(question.payload.options)
        ? '<ul class="options-list compact">' + question.payload.options.map((option, optionIndex) => {
            const correctClass = Number(question.payload.correct) === optionIndex ? 'correct-answer' : '';
            return '<li class="' + correctClass + '">' + optionLetter(optionIndex) + '. ' + option + '</li>';
          }).join('') + '</ul>'
        : '<p class="muted">Тип: ' + question.type + '</p>';

      const connectedPlayersCount = livePlayers.filter((player) => Number(player.connected) === 1).length;
      const isActive = question.id === activeQuestionId;
      const isPlayed = playedQuestionIds.has(question.id);
      const controlsClass = isActive ? '' : 'hidden';
      const answersClass = (isActive || isPlayed) ? '' : 'hidden';
      const showQuestionDisabled = connectedPlayersCount ? '' : 'disabled';
      const hasQuestionVideo = question.payload
        && ((question.payload.videoQuestionUrl && String(question.payload.videoQuestionUrl).trim())
          || (question.payload.mediaType === 'video' && question.payload.mediaUrl));
      const hasQuestionAudio = question.payload
        && ((question.payload.audioQuestionUrl && String(question.payload.audioQuestionUrl).trim())
          || (question.payload.mediaType === 'audio' && question.payload.mediaUrl));
      const hasMedia = Boolean(hasQuestionVideo || hasQuestionAudio);
      const mediaIcon = hasMedia ? (hasQuestionVideo ? ' 🎬' : ' 🔊') : '';

      return '<article class="question-tile" id="question-tile-' + question.id + '" data-question-id="' + question.id + '" data-round-id="' + roundId + '">'
        + '<h4>' + (index + 1) + '. ' + question.title + mediaIcon + '</h4>'
        + optionsHtml
        + '<div class="question-controls">'
        + '  <button class="button show-question" ' + showQuestionDisabled + '>Показать вопрос</button>'
        + '</div>'
        + '<div class="question-live-controls ' + controlsClass + '">'
        + '  <div class="row wrap">'
        + '    <button class="button timer-start">Запустить таймер</button>'
        + '    <button class="button button-outline timer-stop">Остановить таймер</button>'
        + (hasMedia ? '    <button class="button button-outline media-start">Запустить медиа</button>' : '')
        + '    <button class="button reveal-answer">Показать ответ</button>'
        + '    <button class="button button-outline close-question">Скрыть вопрос</button>'
        + '  </div>'
        + '</div>'
        + '<div class="question-live-block ' + answersClass + '">'
        + (isPlayed && !isActive ? '<p class="muted">Вопрос уже сыгран.</p>' : '')
        + '  <div class="table-scroll">'
        + '    <table>'
        + '      <thead><tr><th>Игрок</th><th>Ответ</th><th>Результат</th></tr></thead>'
        + '      <tbody class="answers-table-body">' + renderAnswerRows(question) + '</tbody>'
        + '    </table>'
        + '  </div>'
        + '</div>'
        + '</article>';
    }).join('');

    if (questions.length) {
      questionRibbon.innerHTML += '<div class="row wrap"><button class="button button-outline finish-round">Завершить раунд</button></div>';
    }

    attachQuestionHandlers();
  }

  function attachQuestionHandlers() {
    questionRibbon.querySelectorAll('.question-tile').forEach((tile) => {
      const questionId = Number(tile.dataset.questionId);
      const roundId = Number(tile.dataset.roundId);
      const question = (questionsByRound[roundId] || []).find((q) => q.id === questionId);

      tile.querySelector('.show-question').onclick = async () => {
        if (activeQuestionId === null && selectedRoundId === roundId) {
          await post('/api/admin/games/<%= game.id %>/show-round', { roundId });
        }
        const data = await post('/api/admin/games/<%= game.id %>/show-question', { roundId, questionId });
        if (data.error) {
          alert(data.error);
          return;
        }
        activeQuestionId = questionId;
        renderQuestionRibbon();
        document.getElementById('question-tile-' + questionId)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };

      tile.querySelector('.timer-start').onclick = async () => {
        await post('/api/admin/games/<%= game.id %>/timer/start', { seconds: (question.payload && question.payload.timeLimitSec) || 15 });
      };
      tile.querySelector('.timer-stop').onclick = async () => {
        await post('/api/admin/games/<%= game.id %>/timer/stop');
      };
      const mediaButton = tile.querySelector('.media-start');
      if (mediaButton) {
        mediaButton.onclick = async () => {
          const data = await post('/api/admin/games/<%= game.id %>/media/start');
          if (data.error) {
            alert(data.error);
          }
        };
      }
      tile.querySelector('.reveal-answer').onclick = async () => {
        await post('/api/admin/games/<%= game.id %>/reveal-answer');
      };
      tile.querySelector('.close-question').onclick = async () => {
        await post('/api/admin/games/<%= game.id %>/close-question');
      };
    });
    const finishRoundButton = questionRibbon.querySelector('.finish-round');
    if (finishRoundButton) {
      finishRoundButton.onclick = async () => {
        const data = await post('/api/admin/games/<%= game.id %>/finish-round');
        if (data.error) alert(data.error);
      };
    }
  }

  function renderRoundSelect() {
    if (!roundSelect) return;
    roundSelect.innerHTML = rounds.map((round) => '<option value="' + round.id + '">' + round.name + ' (' + round.question_type + ')</option>').join('');
    roundSelect.onchange = () => {
      selectedRoundId = Number(roundSelect.value);
      activeQuestionId = null;
      post('/api/admin/games/<%= game.id %>/show-round', { roundId: selectedRoundId });
      renderQuestionRibbon();
    };
    selectedRoundId = Number(roundSelect.value);
    renderQuestionRibbon();
  }

  document.getElementById('toggle-qr').onclick = async () => {
    const data = await post('/api/admin/games/<%= game.id %>/screen', { key: 'showQr' });
    if (data && data.screen && data.screen.showQr === false && selectedRoundId) {
      await post('/api/admin/games/<%= game.id %>/show-round', { roundId: selectedRoundId });
    }
  };

  function renderPlayersScoreTable() {
    if (!playersScoreBody) return;
    if (!livePlayers.length) {
      playersScoreBody.innerHTML = '<tr><td colspan="' + (rounds.length + 3) + '">Игроков пока нет.</td></tr>';
      return;
    }

    playersScoreBody.innerHTML = livePlayers.map((player) => {
      const byRoundCells = rounds.map((round) => '<td>' + (liveRoundScores.get(player.id + ':' + round.id) || 0) + '</td>').join('');
      return '<tr>'
        + '<td><strong>' + player.name + '</strong></td>'
        + '<td>' + (player.connected ? 'online' : 'offline') + '</td>'
        + byRoundCells
        + '<td><strong>' + Number(player.score || 0) + '</strong></td>'
        + '</tr>';
    }).join('');
  }

  socket.on('question:show', (question) => {
    activeQuestionId = question.id;
    playedQuestionIds.add(question.id);
    if (!answersByQuestion.has(question.id)) {
      answersByQuestion.set(question.id, []);
    }
    renderQuestionRibbon();
    document.getElementById('question-tile-' + question.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  socket.on('question:status', ({ questionId, status }) => {
    if (status === 'closed' && activeQuestionId === questionId) {
      playedQuestionIds.add(questionId);
      renderQuestionRibbon();
    }
  });

  socket.on('answer:received', (data) => {
    if (!answersByQuestion.has(data.questionId)) {
      answersByQuestion.set(data.questionId, []);
    }
    answersByQuestion.get(data.questionId).push(data);
    if (activeQuestionId === data.questionId) {
      renderQuestionRibbon();
    }
  });

  socket.on('player:list', ({ players }) => {
    livePlayers = players.slice();
    renderPlayersScoreTable();
    renderQuestionRibbon();
  });

  socket.on('player:round-scores', ({ rows }) => {
    rows.forEach((row) => {
      liveRoundScores.set(row.player_id + ':' + row.round_id, Number(row.score || 0));
    });
    renderPlayersScoreTable();
  });

  socket.on('leaderboard:update', ({ leaderboard }) => {
    const scoreMap = new Map(leaderboard.map((row) => [row.playerId || row.id, row.score]));
    livePlayers = livePlayers.map((player) => ({ ...player, score: scoreMap.get(player.id) || player.score || 0 }));
    renderPlayersScoreTable();
  });

  renderRoundSelect();
  renderPlayersScoreTable();
</script>

<%- include('partials/footer') %>
