<%- include('partials/header', { title: 'Управление игрой', user }) %>

<section class="card" style="position:sticky; top:10px; z-index:5;">
  <h1><%= game.title %> • управление игрой</h1>
  <p>
    <a class="button button-outline" href="/admin/games/<%= game.id %>/build">Создание игры</a>
    <a class="button" href="/admin/games/<%= game.id %>/control">Управление игрой</a>
  </p>
  <h2>Быстрый блок ведущего (приоритет)</h2>
  <div id="host-question-box" class="notice">
    Нет активного вопроса.
  </div>
  <div class="row wrap">
    <button class="button" id="start-round">Запустить раунд</button>
    <button class="button" id="next-question">Следующий вопрос</button>
    <button class="button" id="close-question">Закрыть вопрос</button>
    <button class="button" id="reveal-answer">Показать верный ответ</button>
    <button class="button button-danger" id="finish-game">Завершить игру</button>
  </div>
  <div class="inline-form">
    <label for="start-round-id">Раунд:</label>
    <select id="start-round-id">
      <% rounds.forEach((round) => { %>
      <option value="<%= round.id %>"><%= round.name %> (<%= round.question_type %>)</option>
      <% }) %>
    </select>
  </div>
</section>

<details class="card" open>
  <summary><strong>Запуски и история игры</strong></summary>
  <h3>Текущий запуск</h3>
  <% if (currentSessionId) { %>
    <p>Активный запуск: #<%= currentSessionId %></p>
    <button class="button" id="continue-current">Продолжить игру</button>
  <% } else { %>
    <p>Игра еще не запускалась или была завершена.</p>
  <% } %>
  <button class="button" id="start-new">Запустить новую игру</button>

  <h3>История запусков</h3>
  <% if (!sessions.length) { %>
    <p>История пока пустая.</p>
  <% } else { %>
    <table>
      <thead><tr><th>#</th><th>Статус</th><th>Запущена</th><th>Действие</th></tr></thead>
      <tbody>
      <% sessions.forEach((session) => { %>
        <tr>
          <td><%= session.session_number %></td>
          <td><%= session.status %></td>
          <td><%= session.started_at %></td>
          <td>
            <% if (session.status !== 'finished') { %>
              <button class="button button-outline continue-session" data-session-id="<%= session.id %>">Продолжить</button>
            <% } else { %>
              <span>Завершена</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  <% } %>
</details>

<details class="card" open>
  <summary><strong>Настройки игры</strong></summary>
  <p>
    <a class="button" href="/game/<%= game.code %>" target="_blank" rel="noopener noreferrer">Презентация игры</a>
  </p>
  <label>Ссылка для подключения</label>
  <div class="row wrap">
    <input type="text" id="join-link" value="<%= joinUrl %>" readonly />
    <button class="button" type="button" id="copy-link">Скопировать</button>
  </div>
</details>

<details class="card" open>
  <summary><strong>Управление экраном игры</strong></summary>
  <div class="row wrap">
    <button class="button button-outline screen-toggle" data-key="showQr">QR-код</button>
    <button class="button button-outline screen-toggle" data-key="showLeaderboard">Таблица очков</button>
    <button class="button button-outline screen-toggle" data-key="showPlayers">Список игроков</button>
    <button class="button button-outline screen-toggle" data-key="showWinners">Победители</button>
    <button class="button button-outline screen-toggle" data-key="showRoundScores">Итоги раунда</button>
  </div>
</details>

<details class="card" open>
  <summary><strong>Подключенные игроки</strong></summary>
  <div id="players-box">
    <% if (!players.length) { %>
      <p>Игроков пока нет.</p>
    <% } else { %>
      <ul>
        <% players.forEach((player) => { %>
          <li>#<%= player.id %> <strong><%= player.name %></strong> — <%= player.connected ? 'online' : 'offline' %> — <%= player.score %> очков</li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</details>

<details class="card" open>
  <summary><strong>Создание игры</strong></summary>
  <p>Добавление раундов и вопросов вынесено в отдельный раздел, чтобы блок ведущего оставался быстрым.</p>
  <p><a class="button" href="/admin/games/<%= game.id %>/build">Перейти в создание игры</a></p>
</details>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const game = <%- JSON.stringify(game) %>;
  const hostQuestionBox = document.getElementById('host-question-box');

  socket.emit('host:join', { gameCode: game.code });

  document.getElementById('copy-link').onclick = async () => {
    await navigator.clipboard.writeText(document.getElementById('join-link').value);
  };

  async function post(url, body = {}) {
    const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    return response.json();
  }

  document.getElementById('start-new').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/start');
    location.reload();
  };

  const continueCurrent = document.getElementById('continue-current');
  if (continueCurrent) {
    continueCurrent.onclick = async () => {
      await post('/api/admin/games/<%= game.id %>/continue', { sessionId: <%= currentSessionId || 'null' %> });
      location.reload();
    };
  }

  document.querySelectorAll('.continue-session').forEach((button) => {
    button.onclick = async () => {
      await post('/api/admin/games/<%= game.id %>/continue', { sessionId: Number(button.dataset.sessionId) });
      location.reload();
    };
  });

  document.getElementById('start-round').onclick = async () => {
    const roundId = Number(document.getElementById('start-round-id').value);
    await post('/api/admin/games/<%= game.id %>/start-round', { roundId });
  };

  document.getElementById('next-question').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/next-question');
  };

  document.getElementById('close-question').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/close-question');
  };

  document.getElementById('reveal-answer').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/reveal-answer');
  };

  document.getElementById('finish-game').onclick = async () => {
    if (!confirm('Завершить игру сейчас?')) return;
    await post('/api/admin/games/<%= game.id %>/finish');
    location.reload();
  };

  document.querySelectorAll('.screen-toggle').forEach((button) => {
    button.onclick = async () => {
      const data = await post('/api/admin/games/<%= game.id %>/screen', { key: button.dataset.key });
      if (data.screen) {
        button.classList.toggle('button-outline', !data.screen[button.dataset.key]);
      }
    };
  });

  socket.on('player:list', ({ players }) => {
    const box = document.getElementById('players-box');
    if (!players.length) {
      box.innerHTML = '<p>Игроков пока нет.</p>';
      return;
    }
    box.innerHTML = '<ul>' + players.map((player) => '<li>#' + player.id + ' <strong>' + player.name + '</strong> — ' + (player.connected ? 'online' : 'offline') + '</li>').join('') + '</ul>';
  });

  socket.on('question:show', (question) => {
    let answerText = '';
    if (question.type === 'abcd' && question.payload && Array.isArray(question.payload.options)) {
      const idx = Number(question.payload.correct);
      answerText = question.payload.options[idx] ? question.payload.options[idx] : '';
    } else if (question.type === 'text') {
      answerText = question.payload.correctText || '';
    } else if (question.type === 'number') {
      answerText = String(question.payload.correctNumber || '');
    }
    hostQuestionBox.innerHTML = '<strong>Текущий вопрос:</strong> ' + question.title + '<br><strong>Тип:</strong> ' + question.type + '<br><strong>Правильный ответ:</strong> ' + (answerText || '—');
  });

  socket.on('question:closed', () => {
    hostQuestionBox.innerHTML += '<br><em>Вопрос закрыт</em>';
  });

  socket.on('game:finished', () => {
    hostQuestionBox.innerHTML = '<strong>Игра завершена.</strong> Можно запускать новую.';
  });

</script>
<%- include('partials/footer') %>
