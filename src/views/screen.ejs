<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Экран игры</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="fullscreen-page">
  <main class="fullscreen-stage">
    <section class="card fullscreen-card" id="question-block">
      <h1 id="screen-title"><%= game.title %></h1>
      <div class="screen-meta">
        <span><strong>Таймер:</strong> <span id="screen-timer">—</span></span>
      </div>
      <div class="timer-strip"><div id="timer-strip-fill" class="timer-strip-fill"></div></div>
      <div id="screen-content"></div>
      <div id="answer-box" class="notice" style="display:none"></div>
    </section>

    <section class="card fullscreen-card" id="qr-block" style="display:none">
      <h2>Подключение игроков</h2>
      <img src="<%= qrDataUrl %>" alt="QR code" class="qr" />
      <p>Код: <code><%= game.code %></code></p>
      <p><a href="<%= qrUrl %>"><%= qrUrl %></a></p>
    </section>

    <section class="card fullscreen-card" id="players-block" style="display:none"><h2>Игроки</h2><ul id="players-list"></ul></section>
    <section class="card fullscreen-card" id="leaderboard-block" style="display:none">
      <h2>Таблица очков</h2>
      <table><thead><tr><th>Место</th><th>Игрок</th><th>Очки</th></tr></thead><tbody id="leaderboard-body"></tbody></table>
    </section>
    <section class="card fullscreen-card" id="winners-block" style="display:none"><h2>Победители</h2><ol id="winners-list"></ol></section>
    <section class="card fullscreen-card" id="round-scores-block" style="display:none"><h2>Итоги раунда</h2><div id="round-scores"></div></section>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const game = <%- JSON.stringify(game) %>;
    const titleEl = document.getElementById('screen-title');
    const contentEl = document.getElementById('screen-content');
    const timerEl = document.getElementById('screen-timer');
    const timerStripFill = document.getElementById('timer-strip-fill');
    const answerBox = document.getElementById('answer-box');
    const leaderboardBody = document.getElementById('leaderboard-body');
    const winnersList = document.getElementById('winners-list');
    const playersList = document.getElementById('players-list');
    const questionBlock = document.getElementById('question-block');
    const qrBlock = document.getElementById('qr-block');
    const leaderboardBlock = document.getElementById('leaderboard-block');
    const playersBlock = document.getElementById('players-block');
    const winnersBlock = document.getElementById('winners-block');
    const roundScoresBlock = document.getElementById('round-scores-block');

    let timerInterval = null;
    let latestLeaderboard = [];
    let activeTimerDurationMs = 0;

    function enableFullscreen() {
      if (document.fullscreenElement || !document.documentElement.requestFullscreen) return;
      document.documentElement.requestFullscreen().catch(() => {});
    }
    window.addEventListener('load', enableFullscreen);
    document.addEventListener('click', enableFullscreen, { once: true });

    socket.emit('screen:join', { gameCode: game.code });

    socket.on('screen:state', (state) => {
      const showQrOnly = Boolean(state.showQr);
      const showLeaderboardOnly = Boolean(state.showLeaderboard);

      if (showQrOnly || showLeaderboardOnly) {
        questionBlock.style.display = 'none';
        playersBlock.style.display = 'none';
        winnersBlock.style.display = 'none';
        roundScoresBlock.style.display = 'none';
        qrBlock.style.display = showQrOnly ? 'block' : 'none';
        leaderboardBlock.style.display = showLeaderboardOnly ? 'block' : 'none';
      } else {
        questionBlock.style.display = 'block';
        qrBlock.style.display = 'none';
        leaderboardBlock.style.display = 'none';
        playersBlock.style.display = state.showPlayers ? 'block' : 'none';
        winnersBlock.style.display = state.showWinners ? 'block' : 'none';
        roundScoresBlock.style.display = state.showRoundScores ? 'block' : 'none';
      }
      renderWinners(latestLeaderboard);
    });

    socket.on('question:show', (question) => {
      answerBox.style.display = 'none';
      titleEl.innerText = '';
      renderQuestion(question);
      activeTimerDurationMs = Number(question.payload && question.payload.timeLimitSec ? question.payload.timeLimitSec * 1000 : 0);
      startTimer(question.timerEndsAt, activeTimerDurationMs);
    });

    socket.on('question:answer', ({ text, type, payload }) => {
      if (type === 'abcd' && payload && Number.isInteger(Number(payload.correct))) {
        const correctIndex = Number(payload.correct);
        const optionNodes = contentEl.querySelectorAll('[data-option-index]');
        optionNodes.forEach((node) => {
          if (Number(node.dataset.optionIndex) === correctIndex) {
            node.classList.add('option-plate-correct');
          }
        });
      }
      if (type === 'abcd') {
        answerBox.style.display = 'none';
      } else {
        answerBox.innerText = 'Правильный ответ показан';
        answerBox.style.display = 'block';
      }
    });

    socket.on('question:closed', () => {
      stopTimer();
    });

    socket.on('question:timer', ({ timerEndsAt, durationMs }) => {
      if (durationMs) activeTimerDurationMs = Number(durationMs);
      startTimer(timerEndsAt || null, activeTimerDurationMs);
    });

    socket.on('round:finished', ({ rows }) => {
      document.getElementById('round-scores').innerHTML = rows.map((row) => '<div><strong>' + row.name + '</strong>: за раунд ' + row.round_score + ', всего ' + row.total_score + '</div>').join('');
    });

    socket.on('game:finished', () => {
      titleEl.innerText = 'Игра завершена';
      contentEl.innerHTML = '<div class="notice">Ведущий завершил игру. Можно запускать новую сессию.</div>';
      stopTimer();
    });

    socket.on('player:list', ({ players }) => {
      playersList.innerHTML = players.map((p) => '<li>' + p.name + ' — ' + (p.connected ? 'online' : 'offline') + '</li>').join('');
    });

    socket.on('leaderboard:update', ({ leaderboard }) => {
      latestLeaderboard = leaderboard;
      leaderboardBody.innerHTML = '';
      leaderboard.forEach((row) => {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td>' + row.place + '</td><td>' + row.name + '</td><td>' + row.score + '</td>';
        leaderboardBody.appendChild(tr);
      });
      renderWinners(leaderboard);
    });

    function renderWinners(leaderboard) {
      winnersList.innerHTML = '';
      leaderboard.slice(0, 3).forEach((row) => {
        const li = document.createElement('li');
        li.textContent = row.name + ' — ' + row.score;
        winnersList.appendChild(li);
      });
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
      timerEl.innerText = '—';
      timerStripFill.style.width = '0%';
    }

    function startTimer(timerEndsAt, durationMs) {
      stopTimer();
      if (!timerEndsAt) return;

      function tick() {
        const msLeft = Math.max(0, timerEndsAt - Date.now());
        const secLeft = Math.ceil(msLeft / 1000);
        timerEl.innerText = secLeft + ' сек';

        if (durationMs > 0) {
          const percent = Math.max(0, Math.min(100, (msLeft / durationMs) * 100));
          timerStripFill.style.width = percent + '%';
        }

        if (msLeft <= 0) {
          stopTimer();
        }
      }

      tick();
      timerInterval = setInterval(tick, 100);
    }

    function renderQuestionImage(payload) {
      if (!payload || !payload.imageUrl) return;
      const image = document.createElement('img');
      image.src = payload.imageUrl;
      image.alt = 'Изображение вопроса';
      image.className = 'question-media';
      contentEl.appendChild(image);
    }

    function renderQuestion(question) {
      contentEl.innerHTML = '';
      renderQuestionImage(question.payload);

      const title = document.createElement('h2');
      title.className = 'screen-question-title';
      title.innerText = question.title;
      contentEl.appendChild(title);

      if (question.type === 'abcd' && question.payload && Array.isArray(question.payload.options)) {
        const optionsGrid = document.createElement('div');
        optionsGrid.className = 'options-grid';

        question.payload.options.forEach((option, index) => {
          const item = document.createElement('div');
          item.className = 'option-plate';
          item.dataset.optionIndex = String(index);
          item.innerText = String.fromCharCode(65 + index) + '. ' + option;
          optionsGrid.appendChild(item);
        });

        contentEl.appendChild(optionsGrid);
      } else if (question.type === 'buzz') {
        contentEl.innerHTML += '<div class="big-label">Кто быстрее нажмет первым?</div>';
      } else {
        contentEl.innerHTML += '<div class="notice">Вопрос открыт. Игроки отвечают.</div>';
      }
    }
  </script>
</body>
</html>
