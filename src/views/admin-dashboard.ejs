<%- include('partials/header', { title: 'Админка', user }) %>
<section class="card">
  <h1>Панель ведущего</h1>
  <p><a class="button" href="/admin/games/new">Создать игру</a></p>
</section>

<section class="card">
  <h2>Игры</h2>
  <% if (!games.length) { %>
    <p>Нет игр</p>
  <% } else { %>
    <ul>
      <% games.forEach(game => { %>
        <li>
          <strong><%= game.title %></strong> —
          код <code><%= game.code %></code> —
          статус <%= game.status %> —
          <a href="/admin/games/<%= game.id %>/control">Управление</a> |
          <a href="/game/<%= game.code %>">Экран</a> |
          <a href="/join/<%= game.code %>">Вход игроков</a>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>
<%- include('partials/footer') %>
