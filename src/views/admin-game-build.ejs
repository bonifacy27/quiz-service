<%- include('partials/header', { title: 'Создание игры', user }) %>

<section class="card">
  <h1><%= game.title %> • создание игры</h1>
  <p>
    <a class="button" href="/admin/games/<%= game.id %>/build">Создание игры</a>
    <a class="button button-outline" href="/admin/games/<%= game.id %>/control">Управление игрой</a>
  </p>
</section>

<section class="card">
  <h2>Раунды</h2>

  <% if (!rounds.length) { %>
    <p class="muted">Раундов пока нет.</p>
  <% } %>

  <div id="round-list" class="build-round-list modern-rounds">
    <% rounds.forEach((round, roundIndex) => { %>
      <article class="build-round build-round-card <%= editRoundId === round.id ? 'is-open' : 'is-collapsed' %>" data-round-id="<%= round.id %>" data-round-card draggable="true">
        <div class="build-round-header modern-round-header">
          <div>
            <h3>Раунд <%= roundIndex + 1 %></h3>
            <p class="muted small"><strong><%= round.name %></strong></p>
            <p class="muted small"><%= String(round.question_type || '').toUpperCase() %></p>
          </div>
          <div class="row wrap">
            <button class="button button-outline icon-button round-drag-handle" type="button" title="Перетащить раунд">↕</button>
            <form method="post" action="/admin/games/<%= game.id %>/rounds/<%= round.id %>/copy" style="display:inline">
              <button class="button button-outline icon-button" type="submit" title="Копировать">⧉</button>
            </form>
            <form method="post" action="/admin/games/<%= game.id %>/rounds/<%= round.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить раунд и все его вопросы?');">
              <button class="button button-outline icon-button" type="submit" title="Удалить">🗑</button>
            </form>
          </div>
        </div>

        <div class="round-collapsed-actions">
          <button class="button button-outline" type="button" data-round-edit>Редактировать</button>
        </div>

        <div class="round-editor" data-round-editor>
          <details class="round-settings-details">
            <summary><strong>Настройки раунда</strong></summary>
            <form method="post" action="/admin/games/<%= game.id %>/rounds/<%= round.id %>/update" class="round-edit-grid compact-form">
              <label>Название раунда</label>
              <input type="text" name="name" maxlength="120" value="<%= round.name %>" required />

              <label>Тип раунда</label>
              <input type="text" value="<%= round.question_type %>" readonly />
              <input type="hidden" name="questionType" value="<%= round.question_type %>" />

              <label>Описание раунда</label>
              <textarea name="description" rows="2" placeholder="Описание раунда"><%= round.settings.description %></textarea>

              <label>Комментарий для ведущего</label>
              <textarea name="hostComment" rows="2" placeholder="Комментарий для ведущего"><%= round.settings.hostComment %></textarea>

              <div class="round-settings-box">
                <div class="inline-form">
                  <label>Время на ответ</label>
                  <select name="answerTime">
                    <option value="30" <%= round.settings.answerTime === '30' ? 'selected' : '' %>>30 секунд</option>
                    <option value="60" <%= round.settings.answerTime === '60' ? 'selected' : '' %>>60 секунд</option>
                    <option value="custom" <%= round.settings.answerTime === 'custom' ? 'selected' : '' %>>Другое</option>
                  </select>
                </div>
                <div class="inline-form">
                  <label>Свое время (сек)</label>
                  <input type="number" name="customAnswerTimeSec" value="<%= round.settings.customAnswerTimeSec %>" min="1" />
                </div>
                <div class="inline-form">
                  <label>Режим игры</label>
                  <select name="mode">
                    <option value="normal" <%= round.settings.mode === 'normal' ? 'selected' : '' %>>Обычный</option>
                    <option value="fastest" <%= round.settings.mode === 'fastest' ? 'selected' : '' %>>Кто быстрее</option>
                  </select>
                </div>
                <label><input type="checkbox" name="allowAnswerChange" <%= round.settings.allowAnswerChange ? 'checked' : '' %> /> Возможность менять ответ</label>
                <label><input type="checkbox" name="excludeFromTotal" <%= round.settings.excludeFromTotal ? 'checked' : '' %> /> Не учитывать раунд в общем зачете</label>
              </div>

              <button class="button button-outline" type="submit">Сохранить настройки раунда</button>
            </form>
          </details>

          <div class="question-block-list" data-round-questions="<%= round.id %>">
            <% const roundQuestions = questions.filter((question) => question.round_id === round.id); %>
            <% if (!roundQuestions.length) { %>
              <p class="muted">В этом раунде пока нет вопросов.</p>
            <% } %>
            <% roundQuestions.forEach((question, questionIndex) => { %>
              <% const options = Array.isArray(question.payload.options) ? question.payload.options : []; %>
              <% const correct = Number(question.payload.correct); %>
              <article class="build-question compact" data-question-id="<%= question.id %>" draggable="true">
                <div class="build-question-header compact">
                  <span><strong>Вопрос <%= questionIndex + 1 %></strong> — <%= question.title %> <span class="muted">(<%= question.points %>)</span></span>
                  <div class="row wrap">
                    <button class="button button-outline icon-button" type="button" title="Перетащить">↕</button>
                    <form method="post" action="/admin/games/<%= game.id %>/questions/<%= question.id %>/copy" style="display:inline">
                      <button class="button button-outline icon-button" type="submit" title="Копировать">⧉</button>
                    </form>
                    <form method="post" action="/admin/games/<%= game.id %>/questions/<%= question.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить вопрос?');">
                      <button class="button button-outline icon-button" type="submit" title="Удалить">🗑</button>
                    </form>
                  </div>
                </div>

                <% if (question.type === 'abcd') { %>
                  <details open>
                    <summary>Редактировать вопрос</summary>
                    <form method="post" action="/admin/games/<%= game.id %>/questions/<%= question.id %>/compact-edit" class="compact-form question-edit-form" data-edit-abcd>
                      <input type="number" name="points" min="1" step="1" value="<%= question.points %>" required />
                      <input type="text" name="title" maxlength="200" value="<%= question.title %>" required />
                      <input type="hidden" name="imageUrl" value="<%= question.payload.imageUrl || '' %>" class="image-url-input" />
                      <div class="upload-row">
                        <button class="button button-outline image-upload-btn" type="button">Картинка вопроса</button>
                        <input type="file" accept="image/*" class="image-file-input" style="display:none" />
                        <span class="muted image-status"><%= question.payload.imageUrl ? 'Изображение загружено' : '' %></span>
                      </div>
                      <div class="image-preview-wrap" <%= question.payload.imageUrl ? '' : 'style="display:none"' %>>
                        <a href="<%= question.payload.imageUrl || '#' %>" target="_blank" rel="noopener noreferrer" class="image-preview-link">
                          <img src="<%= question.payload.imageUrl || '' %>" alt="preview" class="image-preview-thumb" />
                        </a>
                      </div>
                      <div class="options-editor" data-options-editor>
                        <div class="options-list-box" data-options-list>
                          <% options.forEach((option, optionIndex) => { %>
                            <div class="option-row" data-option-row draggable="true">
                              <label><input type="radio" name="correct" value="<%= optionIndex %>" <%= correct === optionIndex ? 'checked' : '' %> /> <%= String.fromCharCode(65 + optionIndex) %></label>
                              <input type="text" name="options" value="<%= option %>" required />
                              <button type="button" class="button button-outline icon-button remove-option-btn" title="Удалить вариант">🗑</button>
                              <button type="button" class="button button-outline icon-button option-drag-handle" title="Перетащить вариант">☰</button>
                            </div>
                          <% }) %>
                        </div>
                        <button class="button button-outline add-option-btn" type="button">+ Добавить вариант</button>
                      </div>
                      <label>Комментарий для ведущего</label>
                      <textarea name="hostComment" rows="2"><%= question.payload.hostComment || '' %></textarea>
                      <label>Лимит времени (сек)</label>
                      <input type="number" name="timeLimitSec" min="1" value="<%= question.payload.timeLimitSec || 15 %>" />
                      <button class="button" type="submit">Сохранить</button>
                    </form>
                  </details>
                <% } else { %>
                  <details open>
                    <summary>Редактировать вопрос</summary>
                    <a class="button button-outline" href="/admin/games/<%= game.id %>/questions/<%= question.id %>/edit">Открыть расширенное редактирование</a>
                  </details>
                <% } %>
              </article>
            <% }) %>
          </div>

          <div class="question-add-sticky">
            <form method="post" action="/admin/games/<%= game.id %>/questions/create" class="question-add-form compact-form" data-question-form-round="<%= round.id %>">
              <input type="hidden" name="roundId" value="<%= round.id %>" />
              <input type="hidden" name="type" value="<%= round.question_type %>" />
              <input type="hidden" name="imageUrl" value="" class="image-url-input" />

              <% if (round.question_type === 'abcd') { %>
                <div class="question-add-row">
                  <input type="number" name="points" min="1" step="1" value="1" required />
                  <input type="text" name="title" maxlength="200" placeholder="Вопрос" required />
                </div>
                <div class="upload-row">
                  <button class="button button-outline image-upload-btn" type="button">Добавить картинку вопроса</button>
                  <input type="file" accept="image/*" class="image-file-input" style="display:none" />
                  <span class="muted image-status"></span>
                </div>
                <div class="image-preview-wrap" style="display:none">
                  <a href="#" target="_blank" rel="noopener noreferrer" class="image-preview-link">
                    <img src="" alt="preview" class="image-preview-thumb" />
                  </a>
                </div>
                <div class="options-editor" data-options-editor>
                  <div class="options-list-box" data-options-list></div>
                  <button class="button button-outline add-option-btn" type="button">+ Добавить вариант</button>
                </div>
                <label>Комментарий для ведущего</label>
                <textarea name="hostComment" rows="2" placeholder="Комментарий для ведущего"></textarea>
              <% } else { %>
                <div class="question-add-row">
                  <input type="text" name="title" maxlength="200" placeholder="Вопрос" required />
                  <input type="number" name="points" min="1" step="1" value="1" required />
                </div>
                <div data-type-block="text" <%= round.question_type === 'text' ? '' : 'style="display:none"' %>>
                  <input type="text" name="correctText" placeholder="Правильный текст" />
                </div>
                <div data-type-block="number" <%= round.question_type === 'number' ? '' : 'style="display:none"' %>>
                  <input type="number" name="correctNumber" step="any" placeholder="Правильное число" />
                </div>
              <% } %>

              <label>Лимит времени (сек)</label>
              <input type="number" name="timeLimitSec" min="1" value="15" />
              <button class="button" type="submit">Добавить вопрос</button>
              <button class="button button-outline round-close-btn" type="button" data-round-close>Закрыть</button>
            </form>
          </div>

        </div>
      </article>
    <% }) %>
  </div>

  <button class="button" type="button" id="show-round-create">Добавить раунд</button>
  <form method="post" action="/admin/games/<%= game.id %>/rounds" class="round-add-inline" id="round-create-form" hidden>
    <select name="questionType" required>
      <option value="abcd">abcd</option>
      <option value="text">text</option>
      <option value="number">number</option>
      <option value="buzz">buzz</option>
    </select>
    <input type="text" name="name" maxlength="120" placeholder="Название раунда (необязательно)" />
    <button class="button" type="submit">Создать</button>
  </form>
</section>

<script>
  async function postJson(url, body) {
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => ({ error: 'Ошибка' }));
      throw new Error(payload.error || 'Ошибка');
    }
    return response.json();
  }

  async function uploadQuestionImage(fileInput, imageUrlInput, statusEl) {
    const file = fileInput.files && fileInput.files[0];
    if (!file) return;
    statusEl.textContent = 'Загрузка...';
    const formData = new FormData();
    formData.append('image', file);
    const response = await fetch('/admin/uploads/question-image', { method: 'POST', body: formData });
    const data = await response.json();
    if (!response.ok) throw new Error(data.error || 'Ошибка загрузки');
    imageUrlInput.value = data.url;
    statusEl.textContent = 'Изображение загружено';
  }

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>'\"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char]));
  }

  function renderOptionRows(container, values, correctIndex) {
    const options = values.length ? values : ['Вариант A', 'Вариант B', 'Вариант C', 'Вариант D'];
    container.innerHTML = options.map((option, index) => {
      const label = String.fromCharCode(65 + index);
      const checked = Number(correctIndex) === index ? 'checked' : '';
      return '<div class="option-row" data-option-row draggable="true">' +
        '<label><input type="radio" name="correct" value="' + index + '" ' + checked + ' /> ' + label + '</label>' +
        '<input type="text" name="options" value="' + escapeHtml(option) + '" required />' +
        '<button type="button" class="button button-outline icon-button remove-option-btn" title="Удалить вариант">🗑</button>' +
        '<button type="button" class="button button-outline icon-button option-drag-handle" title="Перетащить вариант">☰</button>' +
      '</div>';
    }).join('');
    if (!container.querySelector('input[name="correct"]:checked')) {
      const first = container.querySelector('input[name="correct"]');
      if (first) first.checked = true;
    }
  }

  function collectOptionValues(container) {
    return Array.from(container.querySelectorAll('input[name="options"]')).map((input) => input.value);
  }

  function initOptionDnD(list) {
    let dragged = null;
    list.querySelectorAll('.option-row').forEach((row) => {
      row.addEventListener('dragstart', () => {
        dragged = row;
        row.classList.add('dragging');
      });
      row.addEventListener('dragend', () => {
        row.classList.remove('dragging');
        dragged = null;
        const values = collectOptionValues(list);
        const checked = list.querySelector('input[name="correct"]:checked');
        const checkedIndex = checked ? Number(checked.value) : 0;
        renderOptionRows(list, values, checkedIndex);
        initOptionDnD(list);
      });
      row.addEventListener('dragover', (event) => {
        event.preventDefault();
        if (!dragged || dragged === row) return;
        const rect = row.getBoundingClientRect();
        const after = event.clientY > rect.top + rect.height / 2;
        if (after) row.after(dragged);
        else row.before(dragged);
      });
    });
  }

  function initOptionsEditor(form) {
    const editor = form.querySelector('[data-options-editor]');
    if (!editor) return;
    const list = editor.querySelector('[data-options-list]');
    if (!list) return;

    if (!list.querySelector('[data-option-row]')) {
      renderOptionRows(list, [], 0);
    }
    initOptionDnD(list);

    editor.querySelector('.add-option-btn')?.addEventListener('click', () => {
      const values = collectOptionValues(list);
      values.push('');
      const checked = list.querySelector('input[name="correct"]:checked');
      renderOptionRows(list, values, checked ? Number(checked.value) : 0);
      initOptionDnD(list);
    });

    list.addEventListener('click', (event) => {
      if (!event.target.classList.contains('remove-option-btn')) return;
      const row = event.target.closest('[data-option-row]');
      if (!row) return;
      const values = collectOptionValues(list);
      const rowIndex = Array.from(list.querySelectorAll('[data-option-row]')).indexOf(row);
      if (values.length <= 2) {
        alert('Нужно минимум 2 варианта');
        return;
      }
      values.splice(rowIndex, 1);
      const checked = list.querySelector('input[name="correct"]:checked');
      const checkedIndex = checked ? Number(checked.value) : 0;
      renderOptionRows(list, values, Math.max(0, Math.min(values.length - 1, checkedIndex === rowIndex ? 0 : checkedIndex)));
      initOptionDnD(list);
    });
  }

  function wireImageUpload(form) {
    const button = form.querySelector('.image-upload-btn');
    const fileInput = form.querySelector('.image-file-input');
    const imageUrlInput = form.querySelector('.image-url-input');
    const statusEl = form.querySelector('.image-status');
    const previewWrap = form.querySelector('.image-preview-wrap');
    const previewLink = form.querySelector('.image-preview-link');
    const previewThumb = form.querySelector('.image-preview-thumb');
    if (!button || !fileInput || !imageUrlInput || !statusEl) return;

    button.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', async () => {
      try {
        await uploadQuestionImage(fileInput, imageUrlInput, statusEl);
        if (previewWrap && previewLink && previewThumb) {
          previewWrap.style.display = 'block';
          previewLink.href = imageUrlInput.value;
          previewThumb.src = imageUrlInput.value;
        }
      } catch (error) {
        statusEl.textContent = error.message || 'Ошибка загрузки';
      }
    });
  }

  function resetQuestionDraftForm(form) {
    form.reset();
    const imageUrlInput = form.querySelector('.image-url-input');
    const statusEl = form.querySelector('.image-status');
    const previewWrap = form.querySelector('.image-preview-wrap');
    const previewLink = form.querySelector('.image-preview-link');
    const previewThumb = form.querySelector('.image-preview-thumb');
    if (imageUrlInput) imageUrlInput.value = '';
    if (statusEl) statusEl.textContent = '';
    if (previewWrap) previewWrap.style.display = 'none';
    if (previewLink) previewLink.href = '#';
    if (previewThumb) previewThumb.src = '';

    const optionsList = form.querySelector('[data-options-list]');
    if (optionsList) {
      renderOptionRows(optionsList, [], 0);
      initOptionDnD(optionsList);
    }
  }

  function createQuestionCard(question, gameId) {
    const article = document.createElement('article');
    article.className = 'build-question compact';
    article.dataset.questionId = String(question.id);
    article.draggable = true;
    const options = Array.isArray(question.payload && question.payload.options) ? question.payload.options : [];
    const correct = Number(question.payload && question.payload.correct);
    const optionsHtml = options.map((option, index) => {
      const letter = String.fromCharCode(65 + index);
      const checked = correct === index ? 'checked' : '';
      return '<div class="option-row" data-option-row draggable="true">' +
        '<label><input type="radio" name="correct" value="' + index + '" ' + checked + ' /> ' + letter + '</label>' +
        '<input type="text" name="options" value="' + escapeHtml(option) + '" required />' +
        '<button type="button" class="button button-outline icon-button remove-option-btn" title="Удалить вариант">🗑</button>' +
        '<button type="button" class="button button-outline icon-button option-drag-handle" title="Перетащить вариант">☰</button>' +
      '</div>';
    }).join('');
    const imageUrl = question.payload && question.payload.imageUrl ? question.payload.imageUrl : '';
    const headerHtml =
      '<div class="build-question-header compact">' +
        '<span><strong>Вопрос</strong> ' + escapeHtml(question.title) + ' <span class="muted">(' + question.points + ')</span></span>' +
        '<div class="row wrap">' +
          '<button class="button button-outline icon-button" type="button" title="Перетащить">↕</button>' +
          '<form method="post" action="/admin/games/' + gameId + '/questions/' + question.id + '/copy" style="display:inline"><button class="button button-outline icon-button" type="submit" title="Копировать">⧉</button></form>' +
          '<form method="post" action="/admin/games/' + gameId + '/questions/' + question.id + '/delete" style="display:inline"><button class="button button-outline icon-button" type="submit" title="Удалить">🗑</button></form>' +
        '</div>' +
      '</div>';
    if (question.type !== 'abcd') {
      article.innerHTML = headerHtml +
        '<details open><summary>Редактировать вопрос</summary><a class="button button-outline" href="/admin/games/' + gameId + '/questions/' + question.id + '/edit">Открыть расширенное редактирование</a></details>';
      return article;
    }
    article.innerHTML = headerHtml +
      '<details open><summary>Редактировать вопрос</summary>' +
        '<form method="post" action="/admin/games/' + gameId + '/questions/' + question.id + '/compact-edit" class="compact-form question-edit-form" data-edit-abcd>' +
          '<input type="number" name="points" min="1" step="1" value="' + question.points + '" required />' +
          '<input type="text" name="title" maxlength="200" value="' + escapeHtml(question.title) + '" required />' +
          '<input type="hidden" name="imageUrl" value="' + escapeHtml(imageUrl) + '" class="image-url-input" />' +
          '<div class="upload-row"><button class="button button-outline image-upload-btn" type="button">Картинка вопроса</button><input type="file" accept="image/*" class="image-file-input" style="display:none" /><span class="muted image-status">' + (imageUrl ? 'Изображение загружено' : '') + '</span></div>' +
          '<div class="image-preview-wrap" style="display:' + (imageUrl ? 'block' : 'none') + '"><a href="' + (imageUrl || '#') + '" target="_blank" rel="noopener noreferrer" class="image-preview-link"><img src="' + (imageUrl || '') + '" alt="preview" class="image-preview-thumb" /></a></div>' +
          '<div class="options-editor" data-options-editor><div class="options-list-box" data-options-list>' + optionsHtml + '</div><button class="button button-outline add-option-btn" type="button">+ Добавить вариант</button></div>' +
          '<label>Комментарий для ведущего</label><textarea name="hostComment" rows="2">' + escapeHtml(question.payload && question.payload.hostComment ? question.payload.hostComment : '') + '</textarea>' +
          '<label>Лимит времени (сек)</label><input type="number" name="timeLimitSec" min="1" value="' + Number((question.payload && question.payload.timeLimitSec) || 15) + '" />' +
          '<button class="button" type="submit">Сохранить</button>' +
        '</form>' +
      '</details>';
    return article;
  }

  function bindDnDForQuestion(questionEl, list, gameId) {
    let draggedQuestion = null;
    questionEl.addEventListener('dragstart', () => {
      draggedQuestion = questionEl;
      questionEl.classList.add('dragging');
    });
    questionEl.addEventListener('dragend', async () => {
      questionEl.classList.remove('dragging');
      draggedQuestion = null;
      const roundId = Number(list.dataset.roundQuestions);
      const orderedQuestionIds = Array.from(list.querySelectorAll('.build-question')).map((item) => Number(item.dataset.questionId));
      if (orderedQuestionIds.length) {
        await postJson('/admin/games/' + gameId + '/questions/reorder', { roundId, orderedQuestionIds });
      }
    });
    questionEl.addEventListener('dragover', (event) => {
      event.preventDefault();
      const draggingEl = list.querySelector('.build-question.dragging');
      if (!draggingEl || draggingEl === questionEl) return;
      const rect = questionEl.getBoundingClientRect();
      const after = event.clientY > rect.top + rect.height / 2;
      if (after) questionEl.after(draggingEl);
      else questionEl.before(draggingEl);
    });
  }

  function enableRoundDnD() {
    const list = document.getElementById('round-list');
    if (!list) return;
    let draggedRound = null;
    list.querySelectorAll('.build-round').forEach((roundEl) => {
      roundEl.addEventListener('dragstart', () => {
        draggedRound = roundEl;
        roundEl.classList.add('dragging');
      });
      roundEl.addEventListener('dragend', async () => {
        roundEl.classList.remove('dragging');
        draggedRound = null;
        const orderedRoundIds = Array.from(list.querySelectorAll('.build-round')).map((item) => Number(item.dataset.roundId));
        await postJson('/admin/games/<%= game.id %>/rounds/reorder', { orderedRoundIds });
      });
      roundEl.addEventListener('dragover', (event) => {
        event.preventDefault();
        if (!draggedRound || draggedRound === roundEl) return;
        const rect = roundEl.getBoundingClientRect();
        const after = event.clientY > rect.top + rect.height / 2;
        if (after) roundEl.after(draggedRound);
        else roundEl.before(draggedRound);
      });
    });
  }

  function enableQuestionDnD() {
    document.querySelectorAll('.question-block-list').forEach((list) => {
      list.querySelectorAll('.build-question').forEach((questionEl) => bindDnDForQuestion(questionEl, list, <%= game.id %>));
    });
  }

  function enableCompactAddQuestion() {
    document.querySelectorAll('.question-add-form').forEach((form) => {
      form.classList.add('is-current');
      initOptionsEditor(form);
      wireImageUpload(form);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;
        const activeElement = document.activeElement;
        const activeName = activeElement && activeElement.name ? activeElement.name : null;

        const formData = new FormData(form);
        const payload = {};
        formData.forEach((value, key) => {
          if (payload[key] === undefined) payload[key] = value;
          else if (Array.isArray(payload[key])) payload[key].push(value);
          else payload[key] = [payload[key], value];
        });

        try {
          const data = await postJson(form.action, payload);
          const list = form.closest('.build-round').querySelector('.question-block-list');
          const empty = list.querySelector('.muted');
          if (empty) empty.remove();

          const questionCard = createQuestionCard(data.question, <%= game.id %>);
          list.querySelectorAll('.build-question.is-newly-added').forEach((item) => item.classList.remove('is-newly-added'));
          questionCard.classList.add('is-newly-added');
          list.appendChild(questionCard);
          bindDnDForQuestion(questionCard, list, <%= game.id %>);
          const editForm = questionCard.querySelector('.question-edit-form');
          if (editForm) {
            initOptionsEditor(editForm);
            wireImageUpload(editForm);
          }

          form.querySelector('input[name="title"]').value = '';

          if (activeName) {
            const sameField = form.querySelector('[name="' + activeName + '"]');
            if (sameField) sameField.focus();
          }

          resetQuestionDraftForm(form);

          setTimeout(() => {
            form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }, 80);
        } catch (error) {
          alert(error.message || 'Ошибка добавления вопроса');
        }
      });
    });
  }

  function toggleRoundCard(roundCard, open) {
    roundCard.classList.toggle('is-open', open);
    roundCard.classList.toggle('is-collapsed', !open);
  }

  function initRoundCardActions() {
    document.querySelectorAll('[data-round-card]').forEach((roundCard) => {
      roundCard.querySelector('[data-round-edit]')?.addEventListener('click', () => toggleRoundCard(roundCard, true));
      roundCard.querySelector('[data-round-close]')?.addEventListener('click', () => {
        const draftForm = roundCard.querySelector('.question-add-form');
        if (draftForm) resetQuestionDraftForm(draftForm);
        toggleRoundCard(roundCard, false);
      });
    });

    const showCreateButton = document.getElementById('show-round-create');
    const roundCreateForm = document.getElementById('round-create-form');
    if (showCreateButton && roundCreateForm) {
      showCreateButton.addEventListener('click', () => {
        document.querySelectorAll('.question-add-form').forEach((draftForm) => resetQuestionDraftForm(draftForm));
        roundCreateForm.hidden = !roundCreateForm.hidden;
      });
    }
  }

  document.querySelectorAll('.question-edit-form').forEach((form) => {
    initOptionsEditor(form);
    wireImageUpload(form);
  });

  initRoundCardActions();
  enableRoundDnD();
  enableQuestionDnD();
  enableCompactAddQuestion();
</script>

<%- include('partials/footer') %>
