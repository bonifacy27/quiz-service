<%- include('partials/header', { title: 'Управление игрой', user }) %>
<section class="card">
  <h1><%= game.title %> • запуск #<%= game.id %></h1>

  <h2>1. Начало игры</h2>
  <p>Откройте эту ссылку на проекторе или телевизоре. На этой странице появляются вопросы, ответы и медиа.</p>
  <p>
    <a class="button" href="/game/<%= game.code %>" target="_blank" rel="noopener noreferrer">Презентация игры</a>
  </p>

  <h2>2. Подключение игроков</h2>
  <p>Игроки могут отсканировать QR-код или открыть ссылку и ввести код подключения.</p>
  <div class="row wrap gap">
    <img src="<%= qrDataUrl %>" alt="QR подключения" class="qr" />
    <div>
      <label>Код подключения игроков</label>
      <input type="text" value="<%= game.code %>" readonly />
      <label>Ссылка для подключения</label>
      <div class="row wrap">
        <input type="text" id="join-link" value="<%= joinUrl %>" readonly />
        <button class="button" type="button" id="copy-link">Скопировать</button>
      </div>
    </div>
  </div>
</section>

<section class="card">
  <h2>3. Управление экраном игры</h2>
  <div class="row wrap">
    <button class="button" id="start-game">Запустить игру</button>
    <button class="button" id="next-question">Открыть следующий вопрос</button>
    <button class="button button-danger" id="close-question">Закрыть текущий вопрос</button>
  </div>
  <div class="status-grid">
    <div><strong>Статус вопроса:</strong> <span id="question-status">Нет активного вопроса</span></div>
    <div><strong>Таймер:</strong> <span id="question-timer">—</span></div>
  </div>
  <div id="control-result"></div>
</section>

<section class="card">
  <h2>4. Управление игрой</h2>

  <div class="row wrap">
    <% rounds.forEach((round, index) => { %>
      <button class="button <%= index === 0 ? '' : 'button-outline' %>" type="button" data-round-tab="<%= round.id %>">
        <strong><%= round.name %></strong>
      </button>
    <% }) %>
  </div>

  <form method="post" action="/admin/games/<%= game.id %>/rounds" class="inline-form">
    <input type="text" name="name" maxlength="120" placeholder="Новый раунд" required />
    <button class="button" type="submit">Добавить раунд</button>
  </form>

  <form method="post" id="new-category-form" class="inline-form">
    <input type="hidden" name="roundId" id="new-category-round-id" value="<%= rounds[0] ? rounds[0].id : '' %>" />
    <input type="text" name="name" maxlength="120" placeholder="Новая категория в активном раунде" required />
    <button class="button" type="submit">Добавить категорию</button>
  </form>

  <h3>Добавить вопрос</h3>
  <form method="post" action="/admin/games/<%= game.id %>/questions" id="question-form">
    <label>Раунд</label>
    <select name="roundId" id="question-round-id" required>
      <% rounds.forEach(round => { %>
        <option value="<%= round.id %>"><%= round.name %></option>
      <% }) %>
    </select>

    <label>Категория</label>
    <select name="categoryId" id="question-category-id" required></select>

    <label>Стоимость вопроса</label>
    <input type="number" name="points" min="100" step="100" value="100" required />

    <label>Тип вопроса</label>
    <select name="type" id="question-type" required>
      <option value="abcd">abcd</option>
      <option value="text">text</option>
      <option value="number">number</option>
      <option value="buzz">buzz</option>
    </select>

    <label>Заголовок</label>
    <input type="text" name="title" maxlength="200" required />

    <div data-type-block="abcd">
      <label>Вариант 1</label>
      <input type="text" name="option1" />
      <label>Вариант 2</label>
      <input type="text" name="option2" />
      <label>Вариант 3</label>
      <input type="text" name="option3" />
      <label>Вариант 4</label>
      <input type="text" name="option4" />
      <label>Правильный вариант</label>
      <select name="correct">
        <option value="0">1</option>
        <option value="1">2</option>
        <option value="2">3</option>
        <option value="3">4</option>
      </select>
    </div>

    <div data-type-block="text" style="display:none">
      <label>Правильный текстовый ответ</label>
      <input type="text" name="correctText" />
    </div>

    <div data-type-block="number" style="display:none">
      <label>Правильный числовой ответ</label>
      <input type="number" name="correctNumber" step="any" />
    </div>

    <label>Лимит времени (секунды)</label>
    <input type="number" name="timeLimitSec" min="1" value="15" />

    <button class="button" type="submit">Добавить вопрос</button>
  </form>

  <% rounds.forEach((round, roundIndex) => {
    const roundCategories = categories.filter((category) => category.round_id === round.id);
    const roundQuestions = questions.filter((question) => question.round_id === round.id);
    const pointsSet = Array.from(new Set(roundQuestions.map((question) => question.points))).sort((a, b) => a - b);
  %>
    <div class="round-board" data-round-panel="<%= round.id %>" style="display:<%= roundIndex === 0 ? 'block' : 'none' %>">
      <h3><%= round.name %></h3>
      <% if (!roundCategories.length) { %>
        <p>Категории в этом раунде пока не созданы.</p>
      <% } else if (!pointsSet.length) { %>
        <p>В этом раунде пока нет вопросов.</p>
      <% } else { %>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Категория</th>
                <% pointsSet.forEach((points) => { %>
                  <th><%= points %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% roundCategories.forEach((category) => { %>
                <tr>
                  <td><%= category.name %></td>
                  <% pointsSet.forEach((points) => {
                    const question = roundQuestions.find((item) => item.category_id === category.id && item.points === points);
                  %>
                    <td>
                      <% if (question) { %>
                        <a href="/admin/games/<%= game.id %>/questions/<%= question.id %>/edit">#<%= question.id %></a>
                      <% } else { %>
                        —
                      <% } %>
                    </td>
                  <% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  <% }) %>
</section>

<section class="card">
  <h2>Все вопросы</h2>
  <% if (!questions.length) { %>
    <p>Вопросов нет</p>
  <% } else { %>
    <ol>
      <% questions.forEach(q => { %>
        <li>
          <strong>[<%= q.round_name || 'Без раунда' %> / <%= q.category_name || 'Без категории' %>]</strong>
          [<%= q.type %>] <%= q.title %> — <%= q.points %> очков
          <br>
          <a href="/admin/games/<%= game.id %>/questions/<%= q.id %>/edit">Редактировать</a>
          <form method="post" action="/admin/games/<%= game.id %>/questions/<%= q.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить вопрос? Это действие нельзя отменить.');">
            <button type="submit" class="button-link">Удалить</button>
          </form>
        </li>
      <% }) %>
    </ol>
  <% } %>
</section>

<section class="card">
  <h2>Realtime журнал</h2>
  <div id="log" class="log"></div>
</section>

<section class="card">
  <h2>Leaderboard</h2>
  <table>
    <thead>
      <tr>
        <th>Место</th>
        <th>Игрок</th>
        <th>Очки</th>
      </tr>
    </thead>
    <tbody id="leaderboard-body">
      <% leaderboard.forEach((player, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= player.name %></td>
          <td><%= player.score %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const game = <%- JSON.stringify(game) %>;
  const rounds = <%- JSON.stringify(rounds) %>;
  const categories = <%- JSON.stringify(categories) %>;
  const result = document.getElementById('control-result');
  const log = document.getElementById('log');
  const leaderboardBody = document.getElementById('leaderboard-body');
  const typeSelect = document.getElementById('question-type');
  const questionRoundSelect = document.getElementById('question-round-id');
  const questionCategorySelect = document.getElementById('question-category-id');
  const newCategoryRoundInput = document.getElementById('new-category-round-id');
  const newCategoryForm = document.getElementById('new-category-form');
  const questionStatusEl = document.getElementById('question-status');
  const questionTimerEl = document.getElementById('question-timer');
  const roundTabs = document.querySelectorAll('[data-round-tab]');
  const roundPanels = document.querySelectorAll('[data-round-panel]');
  let timerInterval = null;
  let activeRoundId = rounds[0] ? rounds[0].id : null;

  socket.emit('host:join', { gameCode: game.code });

  function appendLog(text) {
    const line = document.createElement('div');
    line.innerText = new Date().toLocaleTimeString() + ' — ' + text;
    log.prepend(line);
  }

  function updateQuestionTypeForm() {
    const currentType = typeSelect.value;
    document.querySelectorAll('[data-type-block]').forEach((el) => {
      el.style.display = el.dataset.typeBlock === currentType ? 'block' : 'none';
    });
  }

  function stopTimer() {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    questionTimerEl.innerText = '—';
  }

  function startTimer(timerEndsAt) {
    stopTimer();
    if (!timerEndsAt) return;

    function tick() {
      const secLeft = Math.max(0, Math.ceil((timerEndsAt - Date.now()) / 1000));
      questionTimerEl.innerText = secLeft + ' сек';
      if (secLeft <= 0) {
        stopTimer();
      }
    }

    tick();
    timerInterval = setInterval(tick, 250);
  }

  function setQuestionStatus(status, reason) {
    if (status === 'active') {
      questionStatusEl.innerText = 'Активный (прием ответов открыт)';
    } else if (status === 'closed') {
      questionStatusEl.innerText = 'Завершен (прием ответов закрыт)';
      if (reason) {
        appendLog('Вопрос завершен: ' + reason);
      }
      stopTimer();
    } else {
      questionStatusEl.innerText = 'Нет активного вопроса';
      stopTimer();
    }
  }

  function setActiveRound(roundId) {
    activeRoundId = roundId;
    newCategoryRoundInput.value = roundId;

    roundTabs.forEach((tab) => {
      tab.classList.toggle('button-outline', Number(tab.dataset.roundTab) !== Number(roundId));
    });

    roundPanels.forEach((panel) => {
      panel.style.display = Number(panel.dataset.roundPanel) === Number(roundId) ? 'block' : 'none';
    });
  }

  function fillCategoriesForRound(roundId) {
    const filtered = categories.filter((category) => Number(category.round_id) === Number(roundId));
    questionCategorySelect.innerHTML = '';

    filtered.forEach((category) => {
      const option = document.createElement('option');
      option.value = category.id;
      option.innerText = category.name;
      questionCategorySelect.appendChild(option);
    });
  }

  questionRoundSelect.addEventListener('change', () => {
    fillCategoriesForRound(questionRoundSelect.value);
    setActiveRound(questionRoundSelect.value);
  });

  roundTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      setActiveRound(tab.dataset.roundTab);
      questionRoundSelect.value = tab.dataset.roundTab;
      fillCategoriesForRound(tab.dataset.roundTab);
    });
  });

  newCategoryForm.addEventListener('submit', () => {
    newCategoryForm.action = '/admin/games/<%= game.id %>/rounds/' + newCategoryRoundInput.value + '/categories';
  });

  typeSelect.addEventListener('change', updateQuestionTypeForm);
  updateQuestionTypeForm();

  if (rounds.length) {
    setActiveRound(rounds[0].id);
    questionRoundSelect.value = rounds[0].id;
    fillCategoriesForRound(rounds[0].id);
  }

  document.getElementById('copy-link').onclick = async () => {
    const text = document.getElementById('join-link').value;
    await navigator.clipboard.writeText(text);
    appendLog('Ссылка для игроков скопирована');
  };

  document.getElementById('start-game').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/start', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.ok ? 'Игра запущена' : 'Ошибка';
  };

  document.getElementById('next-question').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/next-question', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.finished ? 'Игра завершена' : 'Следующий вопрос открыт';
  };

  document.getElementById('close-question').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/close-question', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.closed ? 'Текущий вопрос завершен досрочно' : 'Активного вопроса нет';
  };

  socket.on('player:list', ({ players }) => {
    appendLog('Подключено игроков: ' + players.length);
  });

  socket.on('answer:received', ({ playerId, answer }) => {
    appendLog('Ответ от игрока #' + playerId + ': ' + JSON.stringify(answer));
  });

  socket.on('question:show', (question) => {
    setQuestionStatus(question.status || 'active');
    startTimer(question.timerEndsAt);
    appendLog('Открыт вопрос #' + question.id + ': ' + question.title);
  });

  socket.on('question:status', ({ status, reason }) => {
    setQuestionStatus(status, reason);
  });

  socket.on('question:closed', ({ questionId, reason }) => {
    setQuestionStatus('closed', reason);
    appendLog('Вопрос #' + questionId + ' закрыт');
  });

  socket.on('leaderboard:update', ({ leaderboard }) => {
    renderLeaderboard(leaderboard);
  });

  function renderLeaderboard(leaderboard) {
    leaderboardBody.innerHTML = '';
    leaderboard.forEach((row) => {
      const tr = document.createElement('tr');
      tr.innerHTML = '<td>' + row.place + '</td><td>' + row.name + '</td><td>' + row.score + '</td>';
      leaderboardBody.appendChild(tr);
    });
  }
</script>
<%- include('partials/footer') %>
