<%- include('partials/header', { title: 'Управление игрой', user }) %>

<section class="card">
  <h1><%= game.title %> • управление игрой</h1>
  <div class="row wrap">
    <a class="button button-outline" href="/admin/games/<%= game.id %>/build">Создание игры</a>
    <a class="button" href="/admin/games/<%= game.id %>/control">Управление игрой</a>
  </div>
</section>

<section class="card">
  <h2>1. Начало игры</h2>
  <p>
    <a class="button" href="/game/<%= game.code %>" target="_blank" rel="noopener noreferrer">Открыть экран игры</a>
  </p>
  <label>Ссылка для подключения</label>
  <div class="row wrap">
    <input type="text" id="join-link" value="<%= joinUrl %>" readonly />
    <button class="button" type="button" id="copy-link">Скопировать</button>
  </div>
  <details>
    <summary>Запуски и история</summary>
    <div class="row wrap">
      <% if (currentSessionId) { %>
        <button class="button" id="continue-current">Продолжить текущий запуск</button>
      <% } %>
      <button class="button" id="start-new">Запустить новую игру</button>
      <button class="button button-danger" id="finish-game">Завершить игру</button>
    </div>
    <% if (sessions.length) { %>
      <table>
        <thead><tr><th>#</th><th>Статус</th><th>Запущена</th><th>Действие</th></tr></thead>
        <tbody>
          <% sessions.forEach((session) => { %>
            <tr>
              <td><%= session.session_number %></td>
              <td><%= session.status %></td>
              <td><%= session.started_at %></td>
              <td>
                <% if (session.status !== 'finished') { %>
                  <button class="button button-outline continue-session" data-session-id="<%= session.id %>">Продолжить</button>
                <% } else { %>
                  <span>Завершена</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </details>
</section>

<section class="card">
  <h2>2. Управление экраном игры</h2>
  <div class="row wrap">
    <button class="button button-outline screen-toggle" data-key="showQr">Показать/скрыть QR-код</button>
    <button class="button button-outline screen-toggle" data-key="showLeaderboard">Показать/скрыть таблицу очков</button>
  </div>
</section>

<section class="card">
  <h2>3. Управление игрой</h2>
  <% if (!rounds.length) { %>
    <p class="notice">Добавьте раунды и вопросы в разделе «Создание игры».</p>
  <% } else { %>
    <label for="round-select">Раунд</label>
    <select id="round-select"></select>

    <div id="question-ribbon" class="question-ribbon"></div>

    <div id="host-question-box" class="notice" style="display:none"></div>
    <div id="question-actions" class="row wrap" style="display:none">
      <button class="button" id="timer-start">Запустить таймер</button>
      <button class="button button-outline" id="timer-stop">Остановить таймер</button>
      <button class="button" id="reveal-answer">Показать ответ</button>
      <button class="button button-outline" id="close-question">Скрыть вопрос</button>
      <button class="button" id="next-question">Следующий вопрос</button>
    </div>

    <div id="answers-box" class="table-scroll" style="display:none">
      <h3>Ответы игроков по текущему вопросу</h3>
      <table>
        <thead><tr><th>Игрок</th><th>Ответ</th><th>Результат</th></tr></thead>
        <tbody id="answers-table-body"></tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="card">
  <h2>4. Управление игроками</h2>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Игрок</th>
          <th>Статус</th>
          <% rounds.forEach((round) => { %>
            <th><%= round.name %></th>
          <% }) %>
          <th>Итого</th>
        </tr>
      </thead>
      <tbody id="players-score-body">
        <% if (!roundScoreTable.length) { %>
          <tr><td colspan="<%= rounds.length + 3 %>">Игроков пока нет.</td></tr>
        <% } else { %>
          <% roundScoreTable.forEach((playerRow) => { %>
            <tr>
              <td><strong><%= playerRow.name %></strong></td>
              <td><%= (players.find((p) => p.id === playerRow.playerId) || {}).connected ? 'online' : 'offline' %></td>
              <% playerRow.byRound.forEach((roundData) => { %>
                <td><%= roundData.score %></td>
              <% }) %>
              <td><strong><%= playerRow.total %></strong></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const game = <%- JSON.stringify(game) %>;
  const rounds = <%- JSON.stringify(rounds) %>;
  const questionsByRound = <%- JSON.stringify(questionsByRound) %>;
  const initialPlayers = <%- JSON.stringify(players) %>;
  const roundScoreTable = <%- JSON.stringify(roundScoreTable) %>;

  socket.emit('host:join', { gameCode: game.code });

  async function post(url, body = {}) {
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    return response.json();
  }

  document.getElementById('copy-link').onclick = async () => {
    await navigator.clipboard.writeText(document.getElementById('join-link').value);
  };

  document.getElementById('start-new').onclick = async () => {
    await post('/api/admin/games/<%= game.id %>/start');
    location.reload();
  };

  const continueCurrent = document.getElementById('continue-current');
  if (continueCurrent) {
    continueCurrent.onclick = async () => {
      await post('/api/admin/games/<%= game.id %>/continue', { sessionId: <%= currentSessionId || 'null' %> });
      location.reload();
    };
  }

  document.querySelectorAll('.continue-session').forEach((button) => {
    button.onclick = async () => {
      await post('/api/admin/games/<%= game.id %>/continue', { sessionId: Number(button.dataset.sessionId) });
      location.reload();
    };
  });

  document.getElementById('finish-game').onclick = async () => {
    if (!confirm('Завершить игру сейчас?')) return;
    await post('/api/admin/games/<%= game.id %>/finish');
    location.reload();
  };

  document.querySelectorAll('.screen-toggle').forEach((button) => {
    button.onclick = async () => {
      const data = await post('/api/admin/games/<%= game.id %>/screen', { key: button.dataset.key });
      if (data.screen) {
        button.classList.toggle('button-outline', !data.screen[button.dataset.key]);
      }
    };
  });

  const roundSelect = document.getElementById('round-select');
  const questionRibbon = document.getElementById('question-ribbon');
  const hostQuestionBox = document.getElementById('host-question-box');
  const questionActions = document.getElementById('question-actions');
  const answersBox = document.getElementById('answers-box');
  const answersTableBody = document.getElementById('answers-table-body');
  const playersScoreBody = document.getElementById('players-score-body');

  let activeQuestion = null;
  let activeQuestionAnswers = [];
  let livePlayers = initialPlayers.slice();
  let liveRoundScores = new Map();

  roundScoreTable.forEach((row) => {
    row.byRound.forEach((roundData) => {
      liveRoundScores.set(row.playerId + ':' + roundData.roundId, Number(roundData.score || 0));
    });
  });

  function optionLetter(index) {
    return String.fromCharCode(65 + index);
  }

  function renderRoundSelect() {
    if (!roundSelect) return;
    roundSelect.innerHTML = rounds.map((round) => '<option value="' + round.id + '">' + round.name + ' (' + round.question_type + ')</option>').join('');
    roundSelect.onchange = renderQuestionRibbon;
    renderQuestionRibbon();
  }

  function renderQuestionRibbon() {
    if (!roundSelect || !questionRibbon) return;
    const roundId = Number(roundSelect.value);
    const questions = questionsByRound[roundId] || [];

    if (!questions.length) {
      questionRibbon.innerHTML = '<p class="notice">В этом раунде нет вопросов.</p>';
      return;
    }

    questionRibbon.innerHTML = questions.map((question, index) => {
      const options = question.type === 'abcd' && question.payload && Array.isArray(question.payload.options)
        ? '<ul class="options-list compact">' + question.payload.options.map((option, optionIndex) => {
            const correctClass = Number(question.payload.correct) === optionIndex ? 'correct-answer' : '';
            return '<li class="' + correctClass + '">' + optionLetter(optionIndex) + '. ' + option + '</li>';
          }).join('') + '</ul>'
        : '<p class="muted">Тип: ' + question.type + '</p>';
      return '<article class="question-tile" data-question-id="' + question.id + '" data-round-id="' + roundId + '">'
        + '<h4>' + (index + 1) + '. ' + question.title + '</h4>'
        + options
        + '<button class="button show-question">Показать вопрос</button>'
        + '</article>';
    }).join('');

    questionRibbon.querySelectorAll('.show-question').forEach((button) => {
      button.onclick = async () => {
        const tile = button.closest('.question-tile');
        const questionId = Number(tile.dataset.questionId);
        const selectedRoundId = Number(tile.dataset.roundId);
        const data = await post('/api/admin/games/<%= game.id %>/show-question', { roundId: selectedRoundId, questionId });
        if (data.error) {
          alert(data.error);
          return;
        }
      };
    });
  }

  function renderActiveQuestion(question) {
    activeQuestion = question;
    activeQuestionAnswers = [];
    answersTableBody.innerHTML = '';
    answersBox.style.display = 'block';

    hostQuestionBox.style.display = 'block';
    questionActions.style.display = 'flex';

    const timerText = question.timerEndsAt ? new Date(question.timerEndsAt).toLocaleTimeString() : 'не запущен';
    hostQuestionBox.innerHTML = '<strong>Активный вопрос:</strong> ' + question.title + '<br><strong>Таймер до:</strong> ' + timerText;
  }

  function findPlayerName(playerId) {
    const player = livePlayers.find((item) => item.id === playerId);
    return player ? player.name : '#' + playerId;
  }

  function formatAnswer(question, answer) {
    if (!question) return '—';
    if (question.type === 'abcd') {
      const idx = Number(answer && answer.optionIndex);
      if (!Number.isInteger(idx)) return '—';
      const optionText = question.payload && question.payload.options && question.payload.options[idx] ? question.payload.options[idx] : '';
      return optionLetter(idx) + '. ' + optionText;
    }
    if (question.type === 'text') return String(answer && answer.text || '—');
    if (question.type === 'number') return String(answer && answer.number || '—');
    return JSON.stringify(answer || {});
  }

  function renderAnswersTable() {
    if (!activeQuestionAnswers.length) {
      answersTableBody.innerHTML = '<tr><td colspan="3">Ответов пока нет.</td></tr>';
      return;
    }
    answersTableBody.innerHTML = activeQuestionAnswers.map((item) => {
      return '<tr>'
        + '<td>' + findPlayerName(item.playerId) + '</td>'
        + '<td>' + formatAnswer(activeQuestion, item.answer) + '</td>'
        + '<td>' + (item.isCorrect ? '✅ верно' : '❌ неверно') + '</td>'
        + '</tr>';
    }).join('');
  }

  function renderPlayersScoreTable() {
    if (!playersScoreBody) return;
    if (!livePlayers.length) {
      playersScoreBody.innerHTML = '<tr><td colspan="' + (rounds.length + 3) + '">Игроков пока нет.</td></tr>';
      return;
    }

    playersScoreBody.innerHTML = livePlayers.map((player) => {
      const byRoundCells = rounds.map((round) => '<td>' + (liveRoundScores.get(player.id + ':' + round.id) || 0) + '</td>').join('');
      return '<tr>'
        + '<td><strong>' + player.name + '</strong></td>'
        + '<td>' + (player.connected ? 'online' : 'offline') + '</td>'
        + byRoundCells
        + '<td><strong>' + Number(player.score || 0) + '</strong></td>'
        + '</tr>';
    }).join('');
  }

  document.getElementById('timer-start')?.addEventListener('click', async () => {
    if (!activeQuestion) return;
    await post('/api/admin/games/<%= game.id %>/timer/start', { seconds: (activeQuestion.payload && activeQuestion.payload.timeLimitSec) || 15 });
  });

  document.getElementById('timer-stop')?.addEventListener('click', async () => {
    await post('/api/admin/games/<%= game.id %>/timer/stop');
  });

  document.getElementById('reveal-answer')?.addEventListener('click', async () => {
    await post('/api/admin/games/<%= game.id %>/reveal-answer');
  });

  document.getElementById('close-question')?.addEventListener('click', async () => {
    await post('/api/admin/games/<%= game.id %>/close-question');
  });

  document.getElementById('next-question')?.addEventListener('click', async () => {
    await post('/api/admin/games/<%= game.id %>/next-question');
  });

  socket.on('question:show', (question) => {
    renderActiveQuestion(question);
  });

  socket.on('question:status', ({ status, reason, timerEndsAt }) => {
    if (!hostQuestionBox || hostQuestionBox.style.display === 'none') return;
    if (status === 'closed') {
      hostQuestionBox.innerHTML += '<br><em>Вопрос завершен (' + reason + ')</em>';
    } else if (timerEndsAt) {
      hostQuestionBox.innerHTML = hostQuestionBox.innerHTML.split('<br><em>')[0] + '<br><strong>Таймер до:</strong> ' + new Date(timerEndsAt).toLocaleTimeString();
    }
  });

  socket.on('answer:received', (data) => {
    if (!activeQuestion || data.questionId !== activeQuestion.id) return;
    activeQuestionAnswers.push(data);
    renderAnswersTable();
  });

  socket.on('player:list', ({ players }) => {
    livePlayers = players.slice();
    renderPlayersScoreTable();
  });

  socket.on('player:round-scores', ({ rows }) => {
    rows.forEach((row) => {
      liveRoundScores.set(row.player_id + ':' + row.round_id, Number(row.score || 0));
    });
    renderPlayersScoreTable();
  });

  socket.on('leaderboard:update', ({ leaderboard }) => {
    const scoreMap = new Map(leaderboard.map((row) => [row.playerId || row.id, row.score]));
    livePlayers = livePlayers.map((player) => ({ ...player, score: scoreMap.get(player.id) || player.score || 0 }));
    renderPlayersScoreTable();
  });

  renderRoundSelect();
  renderAnswersTable();
  renderPlayersScoreTable();
</script>

<%- include('partials/footer') %>
