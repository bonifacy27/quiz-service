<%- include('partials/header', { title: 'Управление игрой', user }) %>
<section class="card">
  <h1><%= game.title %></h1>
  <p>Код: <code><%= game.code %></code></p>
  <p>Экран: <a href="/game/<%= game.code %>">/game/<%= game.code %></a></p>
  <p>Игроки: <a href="/join/<%= game.code %>">/join/<%= game.code %></a></p>
</section>

<section class="card">
  <button class="button" id="start-game">Запустить игру</button>
  <button class="button" id="next-question">Открыть следующий вопрос</button>
  <button class="button button-danger" id="close-question">Завершить текущий вопрос</button>
  <div class="status-grid">
    <div><strong>Статус вопроса:</strong> <span id="question-status">Нет активного вопроса</span></div>
    <div><strong>Таймер:</strong> <span id="question-timer">—</span></div>
  </div>
  <div id="control-result"></div>
</section>

<section class="card">
  <h2>Добавить вопрос</h2>
  <form method="post" action="/admin/games/<%= game.id %>/questions" id="question-form">
    <label>Тип вопроса</label>
    <select name="type" id="question-type" required>
      <option value="abcd">abcd</option>
      <option value="text">text</option>
      <option value="number">number</option>
      <option value="buzz">buzz</option>
    </select>

    <label>Заголовок</label>
    <input type="text" name="title" maxlength="200" required />

    <div data-type-block="abcd">
      <label>Вариант 1</label>
      <input type="text" name="option1" />
      <label>Вариант 2</label>
      <input type="text" name="option2" />
      <label>Вариант 3</label>
      <input type="text" name="option3" />
      <label>Вариант 4</label>
      <input type="text" name="option4" />
      <label>Правильный вариант</label>
      <select name="correct">
        <option value="0">1</option>
        <option value="1">2</option>
        <option value="2">3</option>
        <option value="3">4</option>
      </select>
    </div>

    <div data-type-block="text" style="display:none">
      <label>Правильный текстовый ответ</label>
      <input type="text" name="correctText" />
    </div>

    <div data-type-block="number" style="display:none">
      <label>Правильный числовой ответ</label>
      <input type="number" name="correctNumber" step="any" />
    </div>

    <label>Лимит времени (секунды)</label>
    <input type="number" name="timeLimitSec" min="1" value="15" />

    <button class="button" type="submit">Добавить вопрос</button>
  </form>
</section>

<section class="card">
  <h2>Вопросы</h2>
  <% if (!questions.length) { %>
    <p>Вопросов нет</p>
  <% } else { %>
    <ol>
      <% questions.forEach(q => { %>
        <li>
          <strong>[<%= q.type %>]</strong> <%= q.title %>
          <br>
          <small><code><%= q.payload_json %></code></small>
          <br>
          <a href="/admin/games/<%= game.id %>/questions/<%= q.id %>/edit">Редактировать</a>
          <form method="post" action="/admin/games/<%= game.id %>/questions/<%= q.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить вопрос? Это действие нельзя отменить.');">
            <button type="submit" class="button-link">Удалить</button>
          </form>
        </li>
      <% }) %>
    </ol>
  <% } %>
</section>

<section class="card">
  <h2>Realtime журнал</h2>
  <div id="log" class="log"></div>
</section>

<section class="card">
  <h2>Leaderboard</h2>
  <table>
    <thead>
      <tr>
        <th>Место</th>
        <th>Игрок</th>
        <th>Очки</th>
      </tr>
    </thead>
    <tbody id="leaderboard-body">
      <% leaderboard.forEach((player, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= player.name %></td>
          <td><%= player.score %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const game = <%- JSON.stringify(game) %>;
  const result = document.getElementById('control-result');
  const log = document.getElementById('log');
  const leaderboardBody = document.getElementById('leaderboard-body');
  const typeSelect = document.getElementById('question-type');
  const questionStatusEl = document.getElementById('question-status');
  const questionTimerEl = document.getElementById('question-timer');
  let timerInterval = null;

  socket.emit('host:join', { gameCode: game.code });

  function appendLog(text) {
    const line = document.createElement('div');
    line.innerText = new Date().toLocaleTimeString() + ' — ' + text;
    log.prepend(line);
  }

  function updateQuestionTypeForm() {
    const currentType = typeSelect.value;
    document.querySelectorAll('[data-type-block]').forEach((el) => {
      el.style.display = el.dataset.typeBlock === currentType ? 'block' : 'none';
    });
  }

  function stopTimer() {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    questionTimerEl.innerText = '—';
  }

  function startTimer(timerEndsAt) {
    stopTimer();
    if (!timerEndsAt) return;

    function tick() {
      const secLeft = Math.max(0, Math.ceil((timerEndsAt - Date.now()) / 1000));
      questionTimerEl.innerText = secLeft + ' сек';
      if (secLeft <= 0) {
        stopTimer();
      }
    }

    tick();
    timerInterval = setInterval(tick, 250);
  }

  function setQuestionStatus(status, reason) {
    if (status === 'active') {
      questionStatusEl.innerText = 'Активный (прием ответов открыт)';
    } else if (status === 'closed') {
      questionStatusEl.innerText = 'Завершен (прием ответов закрыт)';
      if (reason) {
        appendLog('Вопрос завершен: ' + reason);
      }
      stopTimer();
    } else {
      questionStatusEl.innerText = 'Нет активного вопроса';
      stopTimer();
    }
  }

  typeSelect.addEventListener('change', updateQuestionTypeForm);
  updateQuestionTypeForm();

  document.getElementById('start-game').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/start', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.ok ? 'Игра запущена' : 'Ошибка';
  };

  document.getElementById('next-question').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/next-question', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.finished ? 'Игра завершена' : 'Следующий вопрос открыт';
  };

  document.getElementById('close-question').onclick = async () => {
    const response = await fetch('/api/admin/games/<%= game.id %>/close-question', {
      method: 'POST'
    });
    const data = await response.json();
    result.innerText = data.closed ? 'Текущий вопрос завершен досрочно' : 'Активного вопроса нет';
  };

  socket.on('player:list', ({ players }) => {
    appendLog('Подключено игроков: ' + players.length);
  });

  socket.on('answer:received', ({ playerId, answer }) => {
    appendLog('Ответ от игрока #' + playerId + ': ' + JSON.stringify(answer));
  });

  socket.on('question:show', (question) => {
    setQuestionStatus(question.status || 'active');
    startTimer(question.timerEndsAt);
    appendLog('Открыт вопрос #' + question.id + ': ' + question.title);
  });

  socket.on('question:status', ({ status, reason }) => {
    setQuestionStatus(status, reason);
  });

  socket.on('question:closed', ({ questionId, reason }) => {
    setQuestionStatus('closed', reason);
    appendLog('Вопрос #' + questionId + ' закрыт');
  });

  socket.on('leaderboard:update', ({ leaderboard }) => {
    renderLeaderboard(leaderboard);
  });

  function renderLeaderboard(leaderboard) {
    leaderboardBody.innerHTML = '';
    leaderboard.forEach((row) => {
      const tr = document.createElement('tr');
      tr.innerHTML = '<td>' + row.place + '</td><td>' + row.name + '</td><td>' + row.score + '</td>';
      leaderboardBody.appendChild(tr);
    });
  }
</script>
<%- include('partials/footer') %>
